<?php

/**
 * @file
 * AI Conversation module.
 */

use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Url;

/**
 * Implements hook_theme().
 */
function ai_conversation_theme() {
  return [
    'ai_conversation_chat' => [
      'variables' => [
        'conversation' => NULL,
        'messages' => [],
        'stats' => NULL,
      ],
      'template' => 'ai-conversation-chat',
    ],
    'user_ai_conversations' => [
      'variables' => [
        'conversations' => [],
        'total' => 0,
      ],
      'template' => 'user-ai-conversations',
    ],
    'ai_usage_dashboard' => [
      'variables' => [
        'statistics' => [],
        'recent_calls' => [],
        'module_breakdown' => [],
        'daily_usage' => [],
      ],
      'template' => 'ai-usage-dashboard',
    ],
    'genai_debug_list' => [
      'variables' => [
        'calls' => [],
        'modules' => [],
        'operations' => [],
        'current_module' => NULL,
        'current_operation' => NULL,
        'current_success' => NULL,
        'current_limit' => 100,
        'current_days' => 0,
        'filtered_total_cost' => 0.0,
        'filtered_total_calls' => 0,
        'alltime_total_cost' => 0.0,
        'alltime_total_calls' => 0,
      ],
      'template' => 'genai-debug-list',
    ],
    'genai_debug_detail' => [
      'variables' => [
        'call_data' => [],
      ],
      'template' => 'genai-debug-detail',
    ],
    'ai_model_pricing' => [
      'variables' => [
        'pricing_data' => [],
      ],
      'template' => 'ai-model-pricing',
    ],
  ];
}

/**
 * Implements hook_entity_view().
 */
function ai_conversation_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'ai_conversation') {
    // Add a link to the chat interface.
    $build['chat_link'] = [
      '#type' => 'link',
      '#title' => t('Start GM Session'),
      '#url' => Url::fromRoute('ai_conversation.chat_interface', ['node' => $entity->id()]),
      '#attributes' => [
        'class' => ['btn', 'btn-primary'],
      ],
      '#weight' => 10,
    ];
  }
}

/**
 * Implements hook_entity_operation().
 */
function ai_conversation_entity_operation(EntityInterface $entity) {
  $operations = [];
  
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'ai_conversation') {
    $operations['chat'] = [
      'title' => t('GM Chat'),
      'url' => Url::fromRoute('ai_conversation.chat_interface', ['node' => $entity->id()]),
      'weight' => 50,
    ];
  }
  
  return $operations;
}
