{#
/**
 * @file
 * Template for GenAI Debug Inspector - Detail View
 *
 * Available variables:
 * - call_data: Full API call record with all fields
 */
#}

{{ attach_library('ai_conversation/genai-debug') }}

<div class="genai-debug-detail">
  {# Header #}
  <div class="genai-debug-card">
    <a href="/admin/reports/genai-debug" class="genai-debug-back-link">← Back to List</a>
    <h2 class="genai-debug-title">GenAI Call Details #{{ call_data.id }}</h2>
  </div>

  {# Metadata Card #}
  <div class="genai-debug-card">
    <h3 class="genai-debug-card-title">Metadata</h3>
    
    <div class="genai-debug-grid-meta">
      <div>
        <strong>Timestamp:</strong> {{ call_data.timestamp }}
      </div>
      <div>
        <strong>User ID:</strong> {{ call_data.uid }}
      </div>
      <div>
        <strong>Module:</strong> <span class="genai-debug-pill">{{ call_data.module }}</span>
      </div>
      <div>
        <strong>Operation:</strong> <code>{{ call_data.operation }}</code>
      </div>
      <div>
        <strong>Model:</strong> {{ call_data.model_id }}
      </div>
      <div>
        <strong>Duration:</strong> {{ call_data.duration_ms }}
      </div>
    </div>

    <div class="genai-debug-grid genai-debug-card-gap-top">
      <div>
        <strong>Max Tokens:</strong> 
        <span class="{% if call_data.max_tokens_used %}genai-debug-pill--highlight{% endif %}">
          {{ call_data.max_tokens_used|default('N/A') }}
        </span>
      </div>
      <div>
        <strong>Input Tokens:</strong> <span class="genai-debug-token-in">{{ call_data.input_tokens }}</span>
      </div>
      <div>
        <strong>Output Tokens:</strong> <span class="genai-debug-token-out">{{ call_data.output_tokens }}</span>
      </div>
      <div>
        <strong>Total Tokens:</strong> <strong>{{ call_data.total_tokens }}</strong>
      </div>
      <div>
        <strong>Cost:</strong> {{ call_data.cost }}
      </div>
    </div>

    <div class="genai-debug-grid genai-debug-card-gap-top">
      <div>
        <strong>Success:</strong> 
        {% if call_data.success %}
          <span class="genai-debug-success genai-debug-yes-no">✅ Yes</span>
        {% else %}
          <span class="genai-debug-fail genai-debug-yes-no">❌ Failed</span>
        {% endif %}
      </div>
      <div>
        <strong>Stop Reason:</strong> 
        <span class="genai-debug-stop-reason {% if call_data.stop_reason == 'max_tokens' %}is-critical{% endif %}">
          {{ call_data.stop_reason|default('N/A') }}
        </span>
      </div>
      {% if call_data.cache_hit is not null %}
      <div>
        <strong>Cache Hit:</strong> {{ call_data.cache_hit ? 'Yes' : 'No' }}
      </div>
      {% endif %}
    </div>

    {% if call_data.error_message %}
      <div class="genai-debug-error-box">
        <strong class="genai-debug-error-label">Error Message:</strong>
        <pre class="genai-debug-pre genai-debug-pre--message">{{ call_data.error_message }}</pre>
      </div>
    {% endif %}
  </div>

  {# Context Data #}
  {% if call_data.context_data %}
    <div class="genai-debug-card">
      <h3 class="genai-debug-card-title">Context Data</h3>
      <pre class="genai-debug-pre">{{ call_data.context_data|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
    </div>
  {% endif %}

  {# Prompt Preview #}
  <div class="genai-debug-card">
    <h3 class="genai-debug-card-title">
      📤 Prompt Sent to GenAI
      <span class="genai-debug-meta-right">
        {{ call_data.prompt_preview|length }} characters
      </span>
    </h3>
    {% if call_data.prompt_preview %}
      <pre class="genai-debug-pre genai-debug-pre--long">{{ call_data.prompt_preview }}</pre>
    {% else %}
      <p class="genai-debug-empty-note">No prompt data available.</p>
    {% endif %}
  </div>

  {# Response Preview #}
  <div class="genai-debug-card">
    <h3 class="genai-debug-card-title">
      📥 Response Received from GenAI
      <span class="genai-debug-meta-right">
        {{ call_data.response_preview|length }} characters
      </span>
    </h3>
    {% if call_data.response_preview %}
      <pre class="genai-debug-pre genai-debug-pre--long">{{ call_data.response_preview }}</pre>
    {% else %}
      <p class="genai-debug-empty-note">No response data available.</p>
    {% endif %}
  </div>

  {# Back to list link at bottom #}
  <div class="genai-debug-footer">
    <a href="/admin/reports/genai-debug" 
       class="genai-debug-link-btn genai-debug-link-btn--primary">
      ← Back to Debug List
    </a>
  </div>
</div>
