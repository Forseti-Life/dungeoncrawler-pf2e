/**
 * Create dc_chat_sessions and dc_chat_messages tables for hierarchical chat.
 *
 * Chat session hierarchy:
 *   campaign  → GM-only master feed (everything feeds here)
 *   dungeon   → per-dungeon aggregate (stored copy, GM + participants)
 *   room      → objective reality log per room (GM "God view")
 *   character_narrative → per-character GM narration (what they perceived)
 *   party     → party huddle (proximity-gated, GM aware)
 *   whisper   → mundane adjacent whisper (Perception-checkable)
 *   spell     → spell-opened private channel (message/telepathy/sending)
 *   gm_private → secret player actions (pickpocket, stealth intent)
 *   system_log → dice, checks, mechanical results
 *   encounter → combat initiative / turn-based narration
 */
function dungeoncrawler_content_update_10024() {
  $schema = \Drupal::database()->schema();

  // ── dc_chat_sessions ────────────────────────────────────────────────
  if (!$schema->tableExists('dc_chat_sessions')) {
    $schema->createTable('dc_chat_sessions', [
      'description' => 'Hierarchical chat session tree. Each row is a scope node.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'campaign_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Owning campaign.',
        ],
        'parent_session_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => FALSE,
          'default' => NULL,
          'description' => 'Parent session in hierarchy. NULL for campaign root.',
        ],
        'session_type' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'description' => 'campaign|dungeon|room|character_narrative|party|whisper|spell|gm_private|system_log|encounter',
        ],
        'session_key' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'description' => 'Deterministic lookup key (e.g. campaign.5.dungeon.12.room.abc).',
        ],
        'scope_ref' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Scope-specific reference (dungeon_id, room_id, character_id, entity_ref).',
        ],
        'label' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Human-readable label for UI.',
        ],
        'metadata' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => TRUE,
          'description' => 'JSON: type-specific metadata (spell_def, perception_dc, narration_buffer, etc.).',
        ],
        'status' => [
          'type' => 'varchar',
          'length' => 16,
          'not null' => TRUE,
          'default' => 'active',
          'description' => 'active|archived|closed',
        ],
        'message_count' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
        ],
        'summary' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => TRUE,
          'description' => 'Compressed summary of older messages for AI context.',
        ],
        'last_message_at' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
        ],
        'updated' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'unique keys' => [
        'session_key' => ['session_key'],
      ],
      'indexes' => [
        'campaign_id' => ['campaign_id'],
        'parent_session_id' => ['parent_session_id'],
        'session_type' => ['session_type'],
        'campaign_type' => ['campaign_id', 'session_type'],
        'status' => ['status'],
      ],
    ]);
  }

  // ── dc_chat_messages ────────────────────────────────────────────────
  if (!$schema->tableExists('dc_chat_messages')) {
    $schema->createTable('dc_chat_messages', [
      'description' => 'Normalized chat messages linked to session hierarchy.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'session_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Primary session this message belongs to.',
        ],
        'campaign_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Denormalized campaign ID for efficient queries.',
        ],
        'speaker' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'description' => 'Display name: Game Master, character name, NPC name, System.',
        ],
        'speaker_type' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'default' => 'system',
          'description' => 'gm|player|npc|system',
        ],
        'speaker_ref' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Character ID, entity_ref, or empty for system/GM.',
        ],
        'message' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => TRUE,
          'description' => 'Message content.',
        ],
        'message_type' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'default' => 'narrative',
          'description' => 'narrative|dialogue|action|mechanical|system|inner_monologue|scene_beat',
        ],
        'visibility' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'default' => 'public',
          'description' => 'public|private|gm_only',
        ],
        'metadata' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => TRUE,
          'description' => 'JSON: dice_rolls, mechanical_actions, perception data, etc.',
        ],
        'feed_targets' => [
          'type' => 'text',
          'size' => 'normal',
          'not null' => TRUE,
          'description' => 'JSON: array of session_ids this message was also pushed to.',
        ],
        'source_message_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => FALSE,
          'default' => NULL,
          'description' => 'If this is a feed-copy, the original message id.',
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'session_id' => ['session_id'],
        'campaign_id' => ['campaign_id'],
        'session_created' => ['session_id', 'created'],
        'speaker_type' => ['speaker_type'],
        'message_type' => ['message_type'],
        'source_message_id' => ['source_message_id'],
      ],
    ]);
  }

  return t('Created dc_chat_sessions and dc_chat_messages tables for hierarchical chat architecture.');
}

/**
 * Add temp_hp column to combat_participants table.
 *
 * PF2e temporary HP: tracked separately, damage absorbs temp HP first,
 * doesn't stack (take higher value), can't be restored by healing.
 */
function dungeoncrawler_content_update_10025() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('combat_participants') && !$schema->fieldExists('combat_participants', 'temp_hp')) {
    $schema->addField('combat_participants', 'temp_hp', [
      'type' => 'int',
      'not null' => TRUE,
      'default' => 0,
      'description' => 'Current temporary hit points (PF2e: absorbs damage first, does not stack).',
    ]);
  }

  return t('Added temp_hp column to combat_participants for PF2e temporary hit points.');
}

/**
 * Create setting template library and campaign setting instance tables.
 *
 * The MapGeneratorService caches AI-generated settings as reusable templates
 * in dungeoncrawler_content_setting_templates. When a player navigates to a
 * new location, the library is checked first before invoking AI generation.
 * Campaign-scoped instances in dc_campaign_settings track per-campaign visits.
 */
function dungeoncrawler_content_update_10026() {
  $schema_handler = \Drupal::database()->schema();
  $module_schema = dungeoncrawler_content_schema();
  $created = [];

  // Library table: setting templates.
  if (!$schema_handler->tableExists('dungeoncrawler_content_setting_templates')) {
    $schema_handler->createTable(
      'dungeoncrawler_content_setting_templates',
      $module_schema['dungeoncrawler_content_setting_templates']
    );
    $created[] = 'dungeoncrawler_content_setting_templates';
  }

  // Campaign table: setting instances.
  if (!$schema_handler->tableExists('dc_campaign_settings')) {
    $schema_handler->createTable(
      'dc_campaign_settings',
      $module_schema['dc_campaign_settings']
    );
    $created[] = 'dc_campaign_settings';
  }

  return t('Created setting library tables: @tables', [
    '@tables' => implode(', ', $created) ?: '(already exist)',
  ]);
}

/**
 * Create room template library table for reusable room content.
 *
 * The RoomGeneratorService catalogues every generated room into
 * dungeoncrawler_content_room_templates as a reusable blueprint.
 * When generating new rooms, the library is checked first — matching
 * rooms by theme, room_type, size_category, and party level range.
 * dc_campaign_rooms.source_room_id links back to template_id.
 */
function dungeoncrawler_content_update_10027() {
  $schema_handler = \Drupal::database()->schema();
  $module_schema = dungeoncrawler_content_schema();
  $created = [];

  if (!$schema_handler->tableExists('dungeoncrawler_content_room_templates')) {
    $schema_handler->createTable(
      'dungeoncrawler_content_room_templates',
      $module_schema['dungeoncrawler_content_room_templates']
    );
    $created[] = 'dungeoncrawler_content_room_templates';
  }

  return t('Created room library tables: @tables', [
    '@tables' => implode(', ', $created) ?: '(already exist)',
  ]);
}

/**
 * Seed all packaged content (setting/room templates, encounters, loot, etc).
 *
 * For existing installs, this runs the ContentSeederService to import all
 * JSON seed files that were previously only available on fresh installs.
 */
function dungeoncrawler_content_update_10028() {
  try {
    /** @var \Drupal\dungeoncrawler_content\Service\ContentSeederService $seeder */
    $seeder = \Drupal::service('dungeoncrawler_content.content_seeder');
    $summary = $seeder->seedAll();
    $total = array_sum($summary);

    $parts = [];
    foreach ($summary as $cat => $count) {
      if ($count > 0) {
        $parts[] = "$cat: $count";
      }
    }

    return t('Seeded @total content records: @breakdown', [
      '@total' => $total,
      '@breakdown' => implode(', ', $parts) ?: '(all already exist)',
    ]);
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10028 content seeder failed: @error', ['@error' => $e->getMessage()]);
    return t('Content seeder failed: @error', ['@error' => $e->getMessage()]);
  }
}

/**
 * Import clan_dagger item into the content registry.
 */
function dungeoncrawler_content_update_10029() {
  /** @var \Drupal\dungeoncrawler_content\Service\ContentRegistry $registry */
  $registry = \Drupal::service('dungeoncrawler_content.content_registry');
  $count = $registry->importContentFromJson('item');
  return t('Imported/refreshed @count item(s) from JSON files (clan_dagger and existing items).', ['@count' => $count]);
}

/**
 * Add discrete ancestry fields to ancestry content type and populate nodes.
 */
function dungeoncrawler_content_update_10030() {
  // --- Field storage definitions ---
  $fields = [
    'field_ancestry_hp' => ['type' => 'integer', 'cardinality' => 1, 'label' => 'Hit Points'],
    'field_ancestry_size' => ['type' => 'string', 'cardinality' => 1, 'label' => 'Size', 'settings' => ['max_length' => 20]],
    'field_ancestry_speed' => ['type' => 'integer', 'cardinality' => 1, 'label' => 'Speed'],
    'field_ancestry_boosts' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Ability Boosts', 'settings' => ['max_length' => 50]],
    'field_ancestry_flaws' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Ability Flaws', 'settings' => ['max_length' => 50]],
    'field_ancestry_languages' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Languages', 'settings' => ['max_length' => 50]],
    'field_ancestry_senses' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Senses', 'settings' => ['max_length' => 50]],
  ];

  foreach ($fields as $field_name => $def) {
    // Create field storage if not exists.
    if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name)) {
      $storage_def = [
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $def['type'],
        'cardinality' => $def['cardinality'],
      ];
      if (!empty($def['settings'])) {
        $storage_def['settings'] = $def['settings'];
      }
      \Drupal\field\Entity\FieldStorageConfig::create($storage_def)->save();
    }
    // Create field instance on ancestry bundle if not exists.
    if (!\Drupal\field\Entity\FieldConfig::loadByName('node', 'ancestry', $field_name)) {
      \Drupal\field\Entity\FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => 'ancestry',
        'label' => $def['label'],
        'required' => FALSE,
      ])->save();
    }
  }

  // --- Populate ancestry nodes from CharacterManager::ANCESTRIES ---
  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'ancestry')
    ->execute();

  $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
  $updated = 0;

  foreach ($nodes as $node) {
    $title = $node->getTitle();
    $canonical = \Drupal\dungeoncrawler_content\Service\CharacterManager::resolveAncestryCanonicalName(strtolower(str_replace(' ', '-', $title)));
    if (empty($canonical)) {
      // Try direct title lookup.
      $all = \Drupal\dungeoncrawler_content\Service\CharacterManager::ANCESTRIES;
      $canonical = isset($all[$title]) ? $title : '';
    }
    if (empty($canonical)) {
      continue;
    }
    $data = \Drupal\dungeoncrawler_content\Service\CharacterManager::ANCESTRIES[$canonical];

    $node->set('field_ancestry_hp', (int) ($data['hp'] ?? 0));
    $node->set('field_ancestry_size', $data['size'] ?? 'Medium');
    $node->set('field_ancestry_speed', (int) ($data['speed'] ?? 25));
    $node->set('field_ancestry_boosts', array_map(fn($b) => ['value' => $b], $data['boosts'] ?? []));
    $node->set('field_ancestry_flaws', array_map(fn($f) => ['value' => $f], array_filter([$data['flaw'] ?? ''])));
    $node->set('field_ancestry_languages', array_map(fn($l) => ['value' => $l], $data['languages'] ?? []));
    $node->set('field_ancestry_senses', !empty($data['vision']) ? [['value' => $data['vision']]] : []);
    $node->save();
    $updated++;
  }

  return t('Added 7 ancestry fields and populated @count ancestry nodes.', ['@count' => $updated]);
}

/**
 * Add discrete background fields to background content type; seed missing
 * core backgrounds (Acrobat, Animal Whisperer, Artisan, Barkeep); populate
 * field data for all background nodes from CharacterManager::BACKGROUNDS.
 */
function dungeoncrawler_content_update_10031() {
  $fields = [
    'field_bg_fixed_boost'    => ['type' => 'string', 'cardinality' => 1, 'label' => 'Fixed Ability Boost',   'settings' => ['max_length' => 20]],
    'field_bg_skill_training' => ['type' => 'string', 'cardinality' => 1, 'label' => 'Skill Training',        'settings' => ['max_length' => 64]],
    'field_bg_lore_skill'     => ['type' => 'string', 'cardinality' => 1, 'label' => 'Lore Skill',            'settings' => ['max_length' => 64]],
    'field_bg_skill_feat'     => ['type' => 'string', 'cardinality' => 1, 'label' => 'Skill Feat',            'settings' => ['max_length' => 128]],
  ];

  foreach ($fields as $field_name => $def) {
    if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name)) {
      $storage_def = [
        'field_name'  => $field_name,
        'entity_type' => 'node',
        'type'        => $def['type'],
        'cardinality' => $def['cardinality'],
        'settings'    => $def['settings'],
      ];
      \Drupal\field\Entity\FieldStorageConfig::create($storage_def)->save();
    }
    if (!\Drupal\field\Entity\FieldConfig::loadByName('node', 'background', $field_name)) {
      \Drupal\field\Entity\FieldConfig::create([
        'field_name'  => $field_name,
        'entity_type' => 'node',
        'bundle'      => 'background',
        'label'       => $def['label'],
        'required'    => FALSE,
      ])->save();
    }
  }

  $backgrounds = \Drupal\dungeoncrawler_content\Service\CharacterManager::BACKGROUNDS;
  $created = 0;
  $updated = 0;

  // Index existing background nodes by title for update.
  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'background')
    ->execute();
  $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
  $existing_by_title = [];
  foreach ($nodes as $node) {
    $existing_by_title[strtolower($node->getTitle())] = $node;
  }

  foreach ($backgrounds as $bg_id => $data) {
    $title_lower = strtolower($data['name']);
    if (isset($existing_by_title[$title_lower])) {
      $node = $existing_by_title[$title_lower];
    }
    else {
      $node = \Drupal\node\Entity\Node::create([
        'type'   => 'background',
        'title'  => $data['name'],
        'status' => 1,
      ]);
      $created++;
    }
    $node->set('field_bg_fixed_boost',    $data['fixed_boost'] ?? '');
    $node->set('field_bg_skill_training', $data['skill']       ?? '');
    $node->set('field_bg_lore_skill',     $data['lore']        ?? '');
    $node->set('field_bg_skill_feat',     $data['feat']        ?? '');
    $node->save();
    $updated++;
  }

  return t('Added 4 background fields; created @new background nodes, populated @total total.', [
    '@new'   => $created,
    '@total' => $updated,
  ]);
}

/**
 * Add discrete fields to character_class content type and populate all 16
 * class nodes from CharacterManager::CLASSES; also seed any missing core
 * PF2E classes.
 */
function dungeoncrawler_content_update_10032() {
  $fields = [
    'field_class_hp_per_level'   => ['type' => 'integer', 'cardinality' => 1,   'label' => 'HP per Level'],
    'field_class_key_ability'    => ['type' => 'string',  'cardinality' => 1,   'label' => 'Key Ability',   'settings' => ['max_length' => 64]],
    'field_class_proficiencies'  => ['type' => 'string_long', 'cardinality' => 1, 'label' => 'Proficiencies (JSON)'],
    'field_class_features'       => ['type' => 'string_long', 'cardinality' => 1, 'label' => 'Level 1 Features (JSON)'],
  ];

  foreach ($fields as $field_name => $def) {
    if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name)) {
      $storage_def = [
        'field_name'  => $field_name,
        'entity_type' => 'node',
        'type'        => $def['type'],
        'cardinality' => $def['cardinality'],
      ];
      if (!empty($def['settings'])) {
        $storage_def['settings'] = $def['settings'];
      }
      \Drupal\field\Entity\FieldStorageConfig::create($storage_def)->save();
    }
    if (!\Drupal\field\Entity\FieldConfig::loadByName('node', 'character_class', $field_name)) {
      \Drupal\field\Entity\FieldConfig::create([
        'field_name'  => $field_name,
        'entity_type' => 'node',
        'bundle'      => 'character_class',
        'label'       => $def['label'],
        'required'    => FALSE,
      ])->save();
    }
  }

  $classes = \Drupal\dungeoncrawler_content\Service\CharacterManager::CLASSES;
  $advancement = \Drupal\dungeoncrawler_content\Service\CharacterManager::CLASS_ADVANCEMENT;

  // Index existing nodes by lowercased title.
  $nids = \Drupal::entityQuery('node')
    ->accessCheck(FALSE)
    ->condition('type', 'character_class')
    ->execute();
  $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
  $existing = [];
  foreach ($nodes as $n) {
    $existing[strtolower($n->getTitle())] = $n;
  }

  $created = 0;
  $updated = 0;

  foreach ($classes as $class_id => $data) {
    $title_lower = strtolower($data['name']);
    if (isset($existing[$title_lower])) {
      $node = $existing[$title_lower];
    }
    else {
      $node = \Drupal\node\Entity\Node::create([
        'type'   => 'character_class',
        'title'  => $data['name'],
        'status' => 1,
      ]);
      $created++;
    }

    $l1_features = $advancement[$class_id][1]['auto_features'] ?? [];

    $node->set('field_class_hp_per_level',  (int) ($data['hp'] ?? 8));
    $node->set('field_class_key_ability',   $data['key_ability'] ?? '');
    $node->set('field_class_proficiencies', json_encode($data['proficiencies'] ?? []));
    $node->set('field_class_features',      json_encode($l1_features));
    $node->save();
    $updated++;
  }

  return t('Added 4 character_class fields; created @new nodes, populated @total total.', [
    '@new'   => $created,
    '@total' => $updated,
  ]);
}

/**
 * Create missing combat_conditions and combat_round_actions tables.
 */
function dungeoncrawler_content_update_10033() {
  $schema = dungeoncrawler_content_schema();
  $db_schema = \Drupal::database()->schema();
  $created = [];
  foreach (['combat_conditions', 'combat_actions'] as $table) {
    if (!$db_schema->tableExists($table)) {
      $db_schema->createTable($table, $schema[$table]);
      $created[] = $table;
    }
  }
  if (empty($created)) {
    return t('combat_conditions and combat_round_actions already exist; no action taken.');
  }
  return t('Created missing tables: @tables.', ['@tables' => implode(', ', $created)]);
}

/**
 * Create dc_requirements table for PF2E requirements roadmap tracking.
 */
function dungeoncrawler_content_update_10034() {
  $db_schema = \Drupal::database()->schema();
  if ($db_schema->tableExists('dc_requirements')) {
    return t('dc_requirements table already exists; no action taken.');
  }
  $schema = [
    'description' => 'PF2E requirements extracted from rulebooks for implementation tracking.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Primary key.',
      ],
      'book_id' => [
        'type' => 'varchar',
        'length' => 16,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Short book identifier: core, apg, gmg, gng, som, gam, b1, b2, b3.',
      ],
      'book_title' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Human-readable book title.',
      ],
      'chapter_key' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Chapter/section key derived from filename, e.g. ch09, s02.',
      ],
      'chapter_title' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Human-readable chapter or section title.',
      ],
      'section' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Section heading from ## SECTION: in the reference file.',
      ],
      'paragraph_title' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Paragraph heading from ### Paragraph — in the reference file.',
      ],
      'req_text' => [
        'type' => 'text',
        'size' => 'medium',
        'not null' => TRUE,
        'description' => 'The requirement text (stripped of leading "- REQ: " prefix).',
      ],
      'req_hash' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'SHA-256 hash of source_file + req_text for deduplication.',
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'pending',
        'description' => 'Implementation status: pending, in_progress, implemented.',
      ],
      'source_file' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Source markdown filename (basename).',
      ],
      'updated_at' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp of last status change.',
      ],
      'updated_by' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'UID of last user to change status.',
      ],
      'feature_id' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Feature identifier linking requirement to a roadmap feature (e.g. dc-cr-spellcasting).',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'req_hash' => ['req_hash'],
    ],
    'indexes' => [
      'book_chapter' => ['book_id', 'chapter_key'],
      'status' => ['status'],
      'idx_feature_id' => ['feature_id'],
    ],
  ];
  $db_schema->createTable('dc_requirements', $schema);
  return t('Created dc_requirements table.');
}

/**
 * Populate Alchemist class advancement features (nid=29) and add research field.
 *
 * Implements hook_update_N().
 */
function dungeoncrawler_content_update_10035() {
  $messages = [];

  // 1. Create field_char_research_field on character content type.
  $field_name = 'field_char_research_field';
  if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name)) {
    \Drupal\field\Entity\FieldStorageConfig::create([
      'field_name'  => $field_name,
      'entity_type' => 'node',
      'type'        => 'string',
      'cardinality' => 1,
      'settings'    => ['max_length' => 64],
    ])->save();
  }
  if (!\Drupal\field\Entity\FieldConfig::loadByName('node', 'character_class', $field_name)) {
    \Drupal\field\Entity\FieldConfig::create([
      'field_name'  => $field_name,
      'entity_type' => 'node',
      'bundle'      => 'character_class',
      'label'       => 'Research Field',
      'required'    => FALSE,
      'description' => 'Alchemist research field selection: bomber, chirurgeon, or mutagenist.',
    ])->save();
    $messages[] = 'Created field_char_research_field on character_class type.';
  }
  else {
    $messages[] = 'field_char_research_field already exists; skipped.';
  }

  // 2. Populate Alchemist nid=29 field_class_features from CLASS_ADVANCEMENT.
  $alchemist_advancement = \Drupal\dungeoncrawler_content\Service\CharacterManager::CLASS_ADVANCEMENT['alchemist'] ?? [];
  if (empty($alchemist_advancement)) {
    $messages[] = 'ERROR: Alchemist CLASS_ADVANCEMENT is empty — no features set.';
    return implode(' | ', $messages);
  }

  $features = [];
  foreach ($alchemist_advancement as $level => $level_data) {
    foreach ($level_data['auto_features'] as $feat) {
      $features[] = array_merge($feat, ['level' => $level]);
    }
  }

  // Load node 29 (Alchemist class node).
  $node = \Drupal::entityTypeManager()->getStorage('node')->load(29);
  if (!$node) {
    $messages[] = 'ERROR: Could not load Alchemist node (nid=29).';
    return implode(' | ', $messages);
  }

  $node->set('field_class_features', json_encode($features));
  $node->save();
  $count = count($features);
  $messages[] = "Populated Alchemist nid=29 field_class_features with {$count} feature entries.";

  return implode(' | ', $messages);
}

