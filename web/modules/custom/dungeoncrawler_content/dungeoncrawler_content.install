  }
  if ($skipped) {
    $msg .= ' Skipped (already exist): ' . implode(', ', $skipped) . '.';
  }
  return t($msg);
}

/**
 * Seed character_class content type and all 12 core PF2E class nodes (dc-cr-character-class).
 *
 * Creates the 'character_class' node type if it does not exist, then seeds
 * one node per class from CharacterManager::CLASSES. The 12 AC-required
 * classes are: alchemist, barbarian, bard, champion, cleric, druid, fighter,
 * monk, ranger, rogue, sorcerer, wizard. Any additional classes in the
