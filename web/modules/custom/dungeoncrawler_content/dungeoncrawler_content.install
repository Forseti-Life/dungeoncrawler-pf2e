/**
 * Migrate combat_participants from Cartesian (x, y) to axial hex (q, r) coordinates.
 */
function dungeoncrawler_content_update_10009() {
  $schema = dungeoncrawler_content_schema();
  $database = \Drupal::database();
  $schema_handler = $database->schema();
  $messages = [];
  $table_name = 'combat_participants';

  try {
    if (!$schema_handler->tableExists($table_name)) {
      return t('Skipped combat participant coordinate migration: @table table does not exist on this site.', [
        '@table' => $table_name,
      ]);
    }

    // Check if old columns exist
    $has_x = $schema_handler->fieldExists($table_name, 'position_x');
    $has_y = $schema_handler->fieldExists($table_name, 'position_y');
    $has_q = $schema_handler->fieldExists($table_name, 'position_q');
    $has_r = $schema_handler->fieldExists($table_name, 'position_r');

    // If new columns already exist and old ones don't, migration already done
    if ($has_q && $has_r && !$has_x && !$has_y) {
      return t('Axial hex coordinates already in place for combat_participants.');
    }

    // Add new columns if they don't exist
    if (!$has_q) {
      $schema_handler->addField($table_name, 'position_q', $schema['combat_participants']['fields']['position_q']);
      $messages[] = 'Added position_q column';
    }
    if (!$has_r) {
      $schema_handler->addField($table_name, 'position_r', $schema['combat_participants']['fields']['position_r']);
      $messages[] = 'Added position_r column';
    }

    // Migrate data: Assume x=q, y=r for simplicity (1:1 mapping)
    // In production, you may need more sophisticated coordinate conversion
    if ($has_x && $has_y) {
      $database->query('UPDATE {' . $table_name . '} SET position_q = position_x, position_r = position_y WHERE position_q IS NULL OR position_r IS NULL');
      $messages[] = 'Migrated position data from (x, y) to (q, r)';

      // Drop old columns
      $schema_handler->dropField($table_name, 'position_x');
      $schema_handler->dropField($table_name, 'position_y');
      $messages[] = 'Dropped position_x and position_y columns';
    }

    if (empty($messages)) {
      return t('No migration needed for combat_participants coordinates.');
    }

    return t('Combat participants coordinate migration complete: @messages', ['@messages' => implode(' ', $messages)]);
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10009 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to migrate combat_participants coordinates: ' . $e->getMessage());
  }
}

