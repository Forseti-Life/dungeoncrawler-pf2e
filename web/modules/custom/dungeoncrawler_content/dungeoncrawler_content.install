/**
 * Create quest system tables (templates, chains, campaign quests, progress).
 */
function dungeoncrawler_content_update_10014() {
  $schema = dungeoncrawler_content_schema();
  $database = \Drupal::database();
  $schema_handler = $database->schema();

  $quest_tables = [
    'dungeoncrawler_content_quest_templates',
    'dungeoncrawler_content_quest_chains',
    'dc_campaign_quests',
    'dc_campaign_quest_progress',
    'dc_campaign_quest_log',
    'dc_campaign_quest_rewards_claimed',
  ];

  $created = [];
  $skipped = [];

  try {
    foreach ($quest_tables as $table_name) {
      if (!$schema_handler->tableExists($table_name)) {
        $schema_handler->createTable($table_name, $schema[$table_name]);
        $created[] = $table_name;
        \Drupal::logger('dungeoncrawler_content')->info('Created quest table: @table', ['@table' => $table_name]);
      }
      else {
        $skipped[] = $table_name;
      }
    }

    $message = '';
    if (!empty($created)) {
      $message .= 'Created quest tables: ' . implode(', ', $created) . '. ';
    }
    if (!empty($skipped)) {
      $message .= 'Skipped existing tables: ' . implode(', ', $skipped) . '.';
    }

    return t($message ?: 'No quest tables needed creation.');
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10014 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to create quest system tables: ' . $e->getMessage());
  }
}

/**
 * Add reaction_available field to combat_participants for PF2E reaction tracking.
 */
function dungeoncrawler_content_update_10015() {
  $schema = \Drupal::database()->schema();
  // Create table if it doesn't exist (may have been added to schema after initial install).
  if (!$schema->tableExists('combat_participants')) {
    $full_schema = dungeoncrawler_content_schema();
    $schema->createTable('combat_participants', $full_schema['combat_participants']);
    \Drupal::logger('dungeoncrawler_content')->notice('Created combat_participants table (reaction_available included in schema).');
    return t('Created combat_participants table (reaction_available included).');
  }
  if (!$schema->fieldExists('combat_participants', 'reaction_available')) {
    $schema->addField('combat_participants', 'reaction_available', [
      'type' => 'int',
      'size' => 'tiny',
      'not null' => TRUE,
      'default' => 1,
      'description' => 'Boolean: reaction available this round (1 = available, 0 = spent).',
    ]);
    // Default all existing participants to reaction available.
    \Drupal::database()->update('combat_participants')
      ->fields(['reaction_available' => 1])
      ->execute();
    return t('Added reaction_available field to combat_participants; all existing participants defaulted to 1 (available).');
  }
  return t('reaction_available field already exists on combat_participants; skipped.');
}

/**
 * Seed ancestry content type and 6 core PF2E ancestry nodes (dc-cr-ancestry-system).
 *
 * Creates the 'ancestry' node type if it does not exist, then seeds one node
 * for each of the 6 core PF2E ancestries from CharacterManager::ANCESTRIES.
 * Data is NOT duplicated — this reads directly from the PHP constants.
 */
function dungeoncrawler_content_update_10016() {
  // Create ancestry content type if it doesn't exist.
  $type = \Drupal\node\Entity\NodeType::load('ancestry');
  if (!$type) {
    $type = \Drupal\node\Entity\NodeType::create([
      'type' => 'ancestry',
      'name' => 'Ancestry',
      'description' => 'PF2E ancestry definitions (dwarf, elf, gnome, goblin, halfling, human, etc.).',
      'settings' => [
        'node' => [
          'options' => ['status' => TRUE, 'promote' => FALSE, 'sticky' => FALSE, 'revision' => FALSE],
          'preview' => DRUPAL_DISABLED,
          'submitted' => FALSE,
        ],
      ],
    ]);
    $type->save();
    \Drupal::logger('dungeoncrawler_content')->notice('Created ancestry content type.');
  }

  // Seed 6 core ancestries (skip extended ancestries for first slice).
  $core_ancestries = ['Human', 'Elf', 'Dwarf', 'Gnome', 'Goblin', 'Halfling'];
  $all_ancestries = \Drupal\dungeoncrawler_content\Service\CharacterManager::ANCESTRIES;
  $created = [];
  $skipped = [];

  foreach ($core_ancestries as $ancestry_name) {
    if (!isset($all_ancestries[$ancestry_name])) {
      continue;
    }
    // Check if a node with this title already exists.
    $existing = \Drupal::entityQuery('node')
      ->condition('type', 'ancestry')
      ->condition('title', $ancestry_name)
      ->accessCheck(FALSE)
      ->execute();

    if (!empty($existing)) {
      $skipped[] = $ancestry_name;
      continue;
    }

    $data = $all_ancestries[$ancestry_name];
    $node = \Drupal\node\Entity\Node::create([
      'type'   => 'ancestry',
      'title'  => $ancestry_name,
      'status' => 1,
      'uid'    => 1,
      'body'   => [
        'value'  => json_encode([
          'hp'        => $data['hp'],
          'size'      => $data['size'],
          'speed'     => $data['speed'],
          'boosts'    => $data['boosts'],
          'flaw'      => $data['flaw'] ?? null,
          'languages' => $data['languages'],
          'senses'    => $data['vision'],
          'traits'    => $data['traits'],
        ], JSON_PRETTY_PRINT),
        'format' => 'plain_text',
      ],
    ]);
    $node->save();
    $created[] = $ancestry_name;
  }

  $msg = 'ancestry content type seeded.';
  if ($created) {
    $msg .= ' Created: ' . implode(', ', $created) . '.';
  }
  if ($skipped) {
    $msg .= ' Skipped (already exist): ' . implode(', ', $skipped) . '.';
  }
  return t($msg);
}

/**
 * Seed background content type and 5 core PF2E background nodes (dc-cr-background-system).
 *
 * Creates the 'background' node type if it does not exist, then seeds one node
 * per background from CharacterManager::BACKGROUNDS (5+ core entries).
