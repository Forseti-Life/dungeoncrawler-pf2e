/**
 * Development-only table consolidation to a single dc_campaign_characters table.
 *
 * This update intentionally ignores existing row contents and can drop data.
 */
function dungeoncrawler_content_update_10007() {
  $schema = dungeoncrawler_content_schema();
  $database = \Drupal::database();
  $schema_handler = $database->schema();
  $messages = [];

  try {
    if (!$schema_handler->tableExists('dc_campaign_characters')) {
      $schema_handler->createTable('dc_campaign_characters', $schema['dc_campaign_characters']);
      $messages[] = 'Created dc_campaign_characters table.';
    }

    $fields_to_add = [
      'uuid',
      'name',
      'level',
      'ancestry',
      'class',
      'character_data',
      'default_character_data',
      'default_locations',
      'portrait',
      'status',
      'created',
      'changed',
    ];

    foreach ($fields_to_add as $field) {
      if (!$schema_handler->fieldExists('dc_campaign_characters', $field)) {
        $schema_handler->addField('dc_campaign_characters', $field, $schema['dc_campaign_characters']['fields'][$field]);
        $messages[] = 'Added dc_campaign_characters.' . $field;
      }
    }

    $indexes = ['name', 'status', 'ancestry', 'class'];
    foreach ($indexes as $index) {
      if (!$schema_handler->indexExists('dc_campaign_characters', $index)) {
        $schema_handler->addIndex('dc_campaign_characters', $index, [$index], $schema['dc_campaign_characters']);
        $messages[] = 'Added index dc_campaign_characters.' . $index;
      }
    }

    if ($schema_handler->tableExists('dc_characters')) {
      $schema_handler->dropTable('dc_characters');
      $messages[] = 'Dropped dc_characters table.';
    }

    if (empty($messages)) {
      return t('Character table consolidation already applied.');
    }

    return t('Character table consolidation complete: @messages', ['@messages' => implode(' ', $messages)]);
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10007 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to consolidate character tables: ' . $e->getMessage());
  }
}

