          'id'             => $class_id,
          'description'    => $class_data['description'],
          'key_ability'    => $class_data['key_ability'],
          'hp_per_level'   => $class_data['hp'],
          'proficiencies'  => $class_data['proficiencies'],
          'trained_skills' => $class_data['trained_skills'],
          'weapons'        => $class_data['weapons'],
          'spellcasting'   => $class_data['spellcasting'] ?? null,
        ], JSON_PRETTY_PRINT),
        'format' => 'plain_text',
      ],
    ]);
    $node->save();
    $created[] = $class_data['name'];
  }

  $msg = 'character_class content type seeded.';
  if ($created) {
    $msg .= ' Created: ' . implode(', ', $created) . '.';
  }
  if ($skipped) {
    $msg .= ' Skipped (already exist): ' . implode(', ', $skipped) . '.';
