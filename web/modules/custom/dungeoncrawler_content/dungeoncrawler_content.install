      'max_stage' => ['type' => 'int', 'not null' => TRUE, 'default' => 3],
      'onset' => ['type' => 'varchar', 'length' => 64, 'not null' => FALSE],
      'onset_elapsed' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0],
      'max_duration' => ['type' => 'int', 'not null' => FALSE],
      'duration_elapsed' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'is_virulent' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0],
      'consecutive_successes' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'stages_json' => ['type' => 'text', 'size' => 'big', 'not null' => TRUE],
      'status' => ['type' => 'varchar', 'length' => 16, 'not null' => TRUE, 'default' => 'active'],
      'created' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'updated' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'encounter_participant' => ['encounter_id', 'participant_id'],
      'status' => ['status'],
    ],
  ];

  $schema->createTable('combat_afflictions', $table_definition);
  return 'Created combat_afflictions table.';
}

