<?php

/**
 * @file
 * Install, update, and uninstall functions for Dungeon Crawler Content module.
 *
 * This file defines the database schema for the Dungeon Crawler game system,
 * including character management, combat encounters, campaign tracking, and
 * procedurally generated content.
 *
 * Update Hook Numbering:
 * - 10001: Initial character table (dc_characters) [DEPRECATED - removed by 10007]
 * - 10002: Game content system tables (registry, loot, encounters)
 * - 10003: Campaign management tables (campaigns, campaign_characters)
 * - 10004: Campaign-scoped content tables (rooms, dungeons, instances)
 * - 10005: Unified entity model (polymorphic character types)
 * - 10007: Consolidate dc_characters → dc_campaign_characters (unified table)
 * - 10010: Generated image asset/link tables
 * - 10014: Quest system tables (templates, chains, campaign quests, progress tracking)
 * - 10021: Import/refresh all game content from JSON files into content registry
 *
 * @see dungeoncrawler_content_schema()
 */

/**
 * Implements hook_schema().
 *
 * Defines all database tables used by the Dungeon Crawler Content module.
 * Tables are organized into logical groups:
 * - Character/Entity Storage: dc_campaign_characters
 * - Campaign Management: dc_campaigns, dc_campaign_characters
 * - Combat System: combat_encounters, combat_participants, combat_conditions, etc.
 * - Content Registry: dungeoncrawler_content_registry, loot_tables, encounter_templates
 * - Campaign-Scoped Content: dc_campaign_* tables for per-campaign instances
 *
 * @return array
 *   Schema definition array for Database API.
 */
function dungeoncrawler_content_schema() {
  // NOTE: dc_characters table was deprecated and removed by update hook 10007.
  // All character data is now stored in dc_campaign_characters (unified table).
  
  $schema['dungeoncrawler_content_registry'] = [
    'description' => 'Registry of all game content (creatures, items, obstacles, traps, hazards).',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Primary key.',
      ],
      'content_type' => [
        'type' => 'varchar',
        'length' => 50,
        'not null' => TRUE,
        'description' => 'Content type: creature, item, obstacle, trap, hazard',
      ],
      'content_id' => [
        'type' => 'varchar',
        'length' => 100,
        'not null' => TRUE,
        'description' => 'Unique identifier (e.g., goblin_warrior)',
      ],
      'name' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'description' => 'Display name',
      ],
      'level' => [
        'type' => 'int',
        'not null' => FALSE,
        'description' => 'Challenge level (for creatures/traps)',
      ],
      'rarity' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => FALSE,
        'description' => 'Rarity: common, uncommon, rare, epic, legendary',
      ],
      'tags' => [
        'type' => 'text',
        'not null' => FALSE,
        'description' => 'JSON array of tags',
      ],
      'schema_data' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => TRUE,
        'description' => 'Full schema content as JSON',
      ],
      'source_file' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'description' => 'Path to source JSON file',
      ],
      'version' => [
        'type' => 'varchar',
        'length' => 20,
        'not null' => FALSE,
        'description' => 'Content version',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when created',
      ],
      'updated' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when updated',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'unique_content' => ['content_type', 'content_id'],
    ],
    'indexes' => [
      'type_level' => ['content_type', 'level'],
      'rarity' => ['rarity'],
    ],
  ];

  $schema['dungeoncrawler_content_loot_tables'] = [
    'description' => 'Loot tables for random item generation.',
