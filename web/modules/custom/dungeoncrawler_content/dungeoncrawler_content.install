/**
 * Add map_id field to combat_encounters for deterministic dungeon lookups.
 */
function dungeoncrawler_content_update_10011() {
  $schema = dungeoncrawler_content_schema();
  $database = \Drupal::database();
  $schema_handler = $database->schema();
  $table_name = 'combat_encounters';

  try {
    // Create table if it doesn't exist (may have been added to schema after initial install).
    if (!$schema_handler->tableExists($table_name)) {
      $schema_handler->createTable($table_name, $schema[$table_name]);
      \Drupal::logger('dungeoncrawler_content')->notice('Created @table table.', ['@table' => $table_name]);
      return t('Created combat_encounters table (map_id included in schema).');
    }

    // Add map_id column if it doesn't exist.
    if (!$schema_handler->fieldExists($table_name, 'map_id')) {
      $spec = [
        'type' => 'varchar',
        'length' => 255,
        'not null' => FALSE,
        'description' => 'Map/dungeon identifier for deterministic dungeon payload lookup.',
      ];
      $schema_handler->addField($table_name, 'map_id', $spec);
    }

    // Add campaign_map index if it doesn't exist.
    if (!$schema_handler->indexExists($table_name, 'campaign_map')) {
      $schema_handler->addIndex($table_name, 'campaign_map', ['campaign_id', 'map_id'], $schema[$table_name]);
    }

    return t('Added map_id field and campaign_map index to combat_encounters table.');
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10011 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to add map_id field to combat_encounters: ' . $e->getMessage());
  }
}

/**
 * Import template content from config/examples/templates/ directory.
 * 
 * This imports all template objects (registry items, item instances, loot tables,
 * etc.) from JSON files into database tables. Includes 129 registry items and
 * 114 item instances from PF2E Core Rulebook + Advanced Players Guide.
 */
function dungeoncrawler_content_update_10012() {
  try {
    $summary = \Drupal::service('dungeoncrawler_content.template_importer')->importTemplates();
    
    $message = t('Template import completed: @processed rows processed, @inserted inserted, @updated updated, @skipped skipped, @errors errors.', [
      '@processed' => $summary['table_rows_processed'] ?? 0,
      '@inserted' => $summary['table_rows_inserted'] ?? 0,
      '@updated' => $summary['table_rows_updated'] ?? 0,
      '@skipped' => $summary['table_rows_skipped'] ?? 0,
      '@errors' => $summary['table_rows_errors'] ?? 0,
    ]);
    
    // Log detailed summary if available
    if (!empty($summary['table_results'])) {
      foreach ($summary['table_results'] as $table => $result) {
        \Drupal::logger('dungeoncrawler_content')->info('Template import for @table: @inserted inserted, @updated updated', [
          '@table' => $table,
          '@inserted' => $result['inserted'] ?? 0,
          '@updated' => $result['updated'] ?? 0,
        ]);
      }
    }
    
    return $message;
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10012 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to import template content: ' . $e->getMessage());
  }
}

