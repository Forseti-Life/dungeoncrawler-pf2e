        'not null' => TRUE,
        'default' => 0,
        'description' => 'GP refunded from most recent Learn a Spell attempt.',
      ],
      'attempted_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp of most recent attempt.',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'character_action_target' => ['character_id', 'action_type', 'target_id'],
    ],
    'indexes' => [
      'character_id'  => ['character_id'],
      'action_type'   => ['action_type'],
      'blocked_until' => ['blocked_until'],
    ],
  ]);

  return 'Created dc_knowledge_attempt_state table (dc-cr-decipher-identify-learn).';
}

/**
 * Implements hook_update_N().
 *
 * Create dc_focus_spell_sources join table for FocusPoolService.
 * Tracks per-character focus spell sources so FocusPoolService.computeMax()
 * can count distinct sources and enforce the cap-of-3 rule (PF2e APG).
 */
function dungeoncrawler_content_update_10041() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('dc_focus_spell_sources')) {
    return 'dc_focus_spell_sources already exists — skipped.';
  }

  $schema->createTable('dc_focus_spell_sources', [
    'description' => 'Tracks focus spell sources per character for FocusPoolService.computeMax().',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Primary key.',
      ],
      'character_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'description' => 'Character identifier.',
      ],
      'source_type' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'class',
        'description' => 'Source category: class, archetype, feat, lesson, revelation, dedication.',
      ],
      'source_description' => [
        'type' => 'varchar',
        'length' => 255,
        'not null' => TRUE,
        'default' => '',
        'description' => 'Human-readable description of the source (e.g., Witch Lesson: Life).',
      ],
      'granted_spell_id' => [
        'type' => 'varchar',
        'length' => 128,
        'not null' => TRUE,
        'description' => 'Focus spell ID granted by this source (e.g., life-boost).',
      ],
      'created' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when source was registered.',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'character_spell' => ['character_id', 'granted_spell_id'],
    ],
    'indexes' => [
      'character_id' => ['character_id'],
    ],
  ]);

  return 'Created dc_focus_spell_sources table (dc-apg-focus-spells).';
}

/**
 * Implements hook_update_N().
 *
 * Create dc_npc and dc_npc_history tables for the NPC System (dc-cr-npc-system).
 */
function dungeoncrawler_content_update_10042() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('dc_npc')) {
    $schema->createTable('dc_npc', [
      'description' => 'Campaign NPC catalog — named allies, contacts, merchants, villains, quest-givers.',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Primary key.',
        ],
        'campaign_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'FK to dc_campaigns.id.',
        ],
        'name' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'description' => 'NPC display name.',
        ],
        'role' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'default' => 'neutral',
          'description' => 'ally|contact|merchant|villain|neutral',
        ],
        'attitude' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'default' => 'indifferent',
          'description' => 'friendly|indifferent|unfriendly|hostile',
        ],
        'level' => [
          'type' => 'int',
          'size' => 'tiny',
          'not null' => TRUE,
          'default' => 1,
          'description' => 'NPC level for abbreviated stat block.',
        ],
        'perception' => [
          'type' => 'int',
          'size' => 'small',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Perception modifier.',
        ],
        'armor_class' => [
          'type' => 'int',
          'size' => 'small',
          'not null' => TRUE,
          'default' => 10,
          'description' => 'Armor Class.',
        ],
        'hit_points' => [
          'type' => 'int',
          'size' => 'small',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Maximum hit points.',
        ],
        'fort_save' => [
          'type' => 'int',
          'size' => 'small',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Fortitude save modifier.',
        ],
        'ref_save' => [
          'type' => 'int',
          'size' => 'small',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Reflex save modifier.',
        ],
        'will_save' => [
          'type' => 'int',
          'size' => 'small',
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Will save modifier.',
        ],
        'lore_notes' => [
          'type' => 'text',
          'not null' => TRUE,
          'description' => 'GM lore/backstory notes; surfaced to AI GM for quest hooks.',
        ],
        'dialogue_notes' => [
          'type' => 'text',
          'not null' => TRUE,
          'description' => 'Dialogue style/hooks for AI GM portrayals.',
        ],
        'entity_ref' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Links to dc_npc_psychology.entity_ref for in-session psychology profile.',
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Unix timestamp of creation.',
        ],
        'updated' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Unix timestamp of last update.',
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'campaign_id' => ['campaign_id'],
        'role' => ['role'],
        'attitude' => ['attitude'],
      ],
    ]);
  }

  if (!$schema->tableExists('dc_npc_history')) {
    $schema->createTable('dc_npc_history', [
      'description' => 'Audit trail for NPC relationship and attitude changes (AC-005).',
      'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'npc_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'FK to dc_npc.id.',
        ],
        'campaign_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'description' => 'Denormalized for fast campaign-level queries.',
        ],
        'session_id' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
          'description' => 'Session in which the change occurred (0 = outside session).',
        ],
        'change_type' => [
          'type' => 'varchar',
          'length' => 32,
          'not null' => TRUE,
          'description' => 'attitude|relationship|note',
        ],
        'old_value' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
        ],
        'new_value' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
        ],
        'trigger' => [
          'type' => 'varchar',
          'length' => 255,
          'not null' => TRUE,
          'default' => '',
          'description' => 'Human-readable trigger (e.g., "Diplomacy DC 15 (rolled 18)").',
        ],
        'created' => [
          'type' => 'int',
          'unsigned' => TRUE,
          'not null' => TRUE,
          'default' => 0,
        ],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'npc_id' => ['npc_id'],
        'campaign_id' => ['campaign_id'],
      ],
    ]);
  }

  return 'Created dc_npc and dc_npc_history tables (dc-cr-npc-system).';
}

/**
 * Add NPC Gallery columns to dc_npc (dc-gmg-hazards).
 *
 * Adds: npc_archetype, alignment, is_gallery_entry, scene_ref,
 * gallery_source_id — enabling the NPC Gallery feature (GMG ch02).
 */
function dungeoncrawler_content_update_10043() {
  $schema = \Drupal::database()->schema();

  $columns = [
    'npc_archetype' => [
      'type'        => 'varchar',
      'length'      => 64,
      'not null'    => TRUE,
      'default'     => '',
      'description' => 'NPC Gallery archetype tag (guard, merchant, assassin, etc.).',
    ],
    'alignment' => [
      'type'        => 'varchar',
      'length'      => 4,
      'not null'    => TRUE,
      'default'     => 'N',
      'description' => 'PF2e alignment code (LG, NG, CG, LN, N, CN, LE, NE, CE).',
    ],
    'is_gallery_entry' => [
      'type'        => 'int',
      'size'        => 'tiny',
      'not null'    => TRUE,
      'default'     => 0,
      'description' => '1 = this is a reusable NPC Gallery archetype; 0 = campaign-specific NPC.',
    ],
    'scene_ref' => [
      'type'        => 'varchar',
      'length'      => 255,
      'not null'    => TRUE,
      'default'     => '',
      'description' => 'Scene/room reference when assigned from gallery (e.g. "room-7").',
    ],
    'gallery_source_id' => [
      'type'        => 'int',
      'unsigned'    => TRUE,
      'not null'    => TRUE,
      'default'     => 0,
      'description' => 'FK to dc_npc.id of the gallery template this was copied from (0 if original).',
    ],
  ];

  foreach ($columns as $column => $spec) {
    if (!$schema->fieldExists('dc_npc', $column)) {
      $schema->addField('dc_npc', $column, $spec);
    }
  }

  // Add indexes for gallery search queries.
  if (!$schema->indexExists('dc_npc', 'gallery_archetype')) {
    $schema->addIndex('dc_npc', 'gallery_archetype', ['is_gallery_entry', 'npc_archetype'], [
      'fields' => [
        'is_gallery_entry' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0],
        'npc_archetype'    => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE, 'default' => ''],
      ],
    ]);
  }
  if (!$schema->indexExists('dc_npc', 'gallery_alignment')) {
    $schema->addIndex('dc_npc', 'gallery_alignment', ['is_gallery_entry', 'alignment'], [
      'fields' => [
        'is_gallery_entry' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0],
        'alignment'        => ['type' => 'varchar', 'length' => 4, 'not null' => TRUE, 'default' => 'N'],
      ],
    ]);
  }

  return 'Added NPC Gallery columns (npc_archetype, alignment, is_gallery_entry, scene_ref, gallery_source_id) to dc_npc (dc-gmg-hazards).';
}

/**
 * Implements hook_update_N().
 *
 * dc-gam-gods-magic: create dc_deities table and import seed catalog.
 */
function dungeoncrawler_content_update_10044() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('dc_deities')) {
    $schema->createTable('dc_deities', [
      'description' => 'Deity catalog for DungeonCrawler (dc-gam-gods-magic).',
      'fields' => [
        'id' => [
          'type'        => 'serial',
          'unsigned'    => TRUE,
          'not null'    => TRUE,
        ],
        'deity_id' => [
          'type'     => 'varchar',
          'length'   => 64,
          'not null' => TRUE,
          'default'  => '',
          'description' => 'Machine-readable slug (e.g. "pharasma").',
        ],
        'name' => [
          'type'     => 'varchar',
          'length'   => 128,
          'not null' => TRUE,
          'default'  => '',
        ],
        'alignment' => [
          'type'     => 'varchar',
          'length'   => 4,
          'not null' => TRUE,
          'default'  => 'N',
          'description' => 'PF2e alignment code (LG, NG, CG, LN, N, CN, LE, NE, CE).',
        ],
        'edicts' => [
          'type'     => 'text',
          'size'     => 'normal',
          'not null' => TRUE,
          'description' => 'JSON-encoded array of edict strings.',
        ],
        'anathema' => [
          'type'     => 'text',
          'size'     => 'normal',
          'not null' => TRUE,
          'description' => 'JSON-encoded array of anathema strings.',
        ],
        'domains' => [
          'type'     => 'text',
          'size'     => 'normal',
          'not null' => TRUE,
          'description' => 'JSON-encoded {primary: [], alternate: []} domain lists.',
        ],
        'divine_font' => [
          'type'     => 'varchar',
          'length'   => 8,
          'not null' => TRUE,
          'default'  => 'heal',
          'description' => 'heal | harm | both',
        ],
        'divine_skill' => [
          'type'     => 'varchar',
          'length'   => 32,
          'not null' => TRUE,
          'default'  => '',
        ],
        'favored_weapon' => [
          'type'     => 'varchar',
          'length'   => 64,
          'not null' => TRUE,
          'default'  => '',
          'description' => 'Equipment catalog slug for the deity\'s favored weapon.',
        ],
        'cleric_spells' => [
          'type'     => 'text',
          'size'     => 'normal',
          'not null' => TRUE,
          'description' => 'JSON-encoded {level: spell_id} map of signature cleric spells.',
        ],
        'divine_ability' => [
          'type'     => 'text',
          'size'     => 'normal',
          'not null' => TRUE,
          'description' => 'JSON-encoded array of two ability score options (e.g. ["WIS","CHA"]).',
        ],
        'changed' => [
          'type'     => 'int',
          'not null' => TRUE,
          'default'  => 0,
          'description' => 'Unix timestamp of last update.',
        ],
      ],
      'primary key' => ['id'],
      'unique keys' => [
        'deity_id' => ['deity_id'],
      ],
      'indexes' => [
        'alignment'    => ['alignment'],
        'divine_font'  => ['divine_font'],
      ],
    ]);
  }

  // Import seed catalog into the new table.
  /** @var \Drupal\dungeoncrawler_content\Service\DeityService $deity_service */
  $deity_service = \Drupal::service('dungeoncrawler_content.deity_catalog');
  $count = $deity_service->importSeedCatalog();

  return "Created dc_deities table and imported {$count} seed deities (dc-gam-gods-magic).";
}

/**
 * dc-gmg-running-guide: Create GM Running Guide operational tables.
 *
 * Tables created:
 *  - dc_gm_reference       — GMG reference content entries
 *  - dc_gm_session_zero    — Session zero records per campaign
 *  - dc_gm_dashboard       — GM dashboard modifier cache
 *  - dc_gm_secret_reveal   — Secret check reveal log
 *  - dc_gm_ruling          — Ruling records with precedent linkage
 *  - dc_gm_safety          — Safety tool configuration per campaign
 *  - dc_story_point        — Story Point economy ledger
 *  - dc_gm_rarity          — Content rarity allowlist per campaign
 *  - dc_encounter_metadata — Encounter narrative metadata
 *  - dc_gm_adventure_design — Adventure/scene design records
 *  - dc_gm_campaign_design  — Campaign design preferences
 */
function dungeoncrawler_content_update_10046() {
  $schema = \Drupal::database()->schema();

  // ── dc_gm_reference ────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_reference')) {
    $schema->createTable('dc_gm_reference', [
      'fields' => [
        'id'                   => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'section'              => ['type' => 'varchar', 'length' => 64,   'not null' => TRUE, 'default' => ''],
        'title'                => ['type' => 'varchar', 'length' => 255,  'not null' => TRUE, 'default' => ''],
        'content_markdown'     => ['type' => 'text',   'size' => 'big',  'not null' => TRUE],
        'tags_json'            => ['type' => 'text',   'size' => 'normal','not null' => TRUE, 'default' => '[]'],
        'structured_data_json' => ['type' => 'text',   'size' => 'big'],
        'source_book'          => ['type' => 'varchar', 'length' => 32,   'not null' => TRUE, 'default' => 'gmg'],
        'created'              => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'              => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'section'    => ['section'],
        'source_book'=> ['source_book'],
      ],
    ]);
  }

  // ── dc_gm_session_zero ─────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_session_zero')) {
    $schema->createTable('dc_gm_session_zero', [
      'fields' => [
        'id'                   => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'          => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'pc_links_json'        => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'character_hooks_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'player_prefs_json'    => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'adventure_hooks_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'created'              => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'              => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign' => ['campaign_id']],
    ]);
  }

  // ── dc_gm_dashboard ────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_dashboard')) {
    $schema->createTable('dc_gm_dashboard', [
      'fields' => [
        'id'                 => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'pc_snapshots_json'  => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'refreshed_at'       => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign' => ['campaign_id']],
    ]);
  }

  // ── dc_gm_secret_reveal ────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_secret_reveal')) {
    $schema->createTable('dc_gm_secret_reveal', [
      'fields' => [
        'id'          => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id' => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'session_id'  => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'roll_ref'    => ['type' => 'varchar', 'length' => 128,   'not null' => TRUE, 'default' => ''],
        'revealed'    => ['type' => 'int',    'size' => 'tiny',   'not null' => TRUE, 'default' => 0],
        'actual_roll' => ['type' => 'int'],
        'gm_id'       => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'created'     => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'campaign_session' => ['campaign_id', 'session_id'],
      ],
    ]);
  }

  // ── dc_gm_ruling ───────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_ruling')) {
    $schema->createTable('dc_gm_ruling', [
      'fields' => [
        'id'              => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'     => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'gm_id'           => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'title'           => ['type' => 'varchar', 'length' => 255,   'not null' => TRUE, 'default' => ''],
        'description'     => ['type' => 'text',   'size' => 'big'],
        'is_provisional'  => ['type' => 'int',    'size' => 'tiny',   'not null' => TRUE, 'default' => 0],
        'deferred_review' => ['type' => 'int',    'size' => 'tiny',   'not null' => TRUE, 'default' => 0],
        'precedent_ref'   => ['type' => 'int',    'unsigned' => TRUE],
        'is_exception'    => ['type' => 'int',    'size' => 'tiny',   'not null' => TRUE, 'default' => 0],
        'review_notes'    => ['type' => 'text',   'size' => 'big'],
        'reviewed_at'     => ['type' => 'int',    'unsigned' => TRUE],
        'created'         => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'         => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'campaign'      => ['campaign_id'],
        'provisional'   => ['campaign_id', 'is_provisional'],
      ],
    ]);
  }

  // ── dc_gm_safety ───────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_safety')) {
    $schema->createTable('dc_gm_safety', [
      'fields' => [
        'id'                  => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'         => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'lethality_level'     => ['type' => 'varchar', 'length' => 16,   'not null' => TRUE, 'default' => 'heroic'],
        'tpk_handling'        => ['type' => 'varchar', 'length' => 32,   'not null' => TRUE, 'default' => 'pause_and_discuss'],
        'xcard_enabled'       => ['type' => 'int',    'size' => 'tiny',   'not null' => TRUE, 'default' => 1],
        'lines_json'          => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'veils_json'          => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'governance_policy'   => ['type' => 'text',   'size' => 'big'],
        'zero_tolerance_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'created'             => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'             => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign' => ['campaign_id']],
    ]);
  }

  // ── dc_story_point ─────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_story_point')) {
    $schema->createTable('dc_story_point', [
      'fields' => [
        'id'               => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'      => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'player_id'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'points_available' => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'points_used'      => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'last_updated'     => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign_player' => ['campaign_id', 'player_id']],
    ]);
  }

  // ── dc_gm_rarity ───────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_rarity')) {
    $schema->createTable('dc_gm_rarity', [
      'fields' => [
        'id'             => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'    => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'allowlist_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'denylist_json'  => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'organized_play' => ['type' => 'int',    'size' => 'tiny',   'not null' => TRUE, 'default' => 0],
        'created'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign' => ['campaign_id']],
    ]);
  }

  // ── dc_encounter_metadata ──────────────────────────────────────────────
  if (!$schema->tableExists('dc_encounter_metadata')) {
    $schema->createTable('dc_encounter_metadata', [
      'fields' => [
        'id'                  => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'         => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'encounter_id'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'purpose'             => ['type' => 'text',   'size' => 'big'],
        'adversary_rationale' => ['type' => 'text',   'size' => 'big'],
        'location_hooks_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'setup_profile'       => ['type' => 'varchar', 'length' => 32],
        'dynamic_twists_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'emotional_beat'      => ['type' => 'varchar', 'length' => 128,  'not null' => TRUE, 'default' => ''],
        'created'             => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'             => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign_encounter' => ['campaign_id', 'encounter_id']],
    ]);
  }

  // ── dc_gm_adventure_design ─────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_adventure_design')) {
    $schema->createTable('dc_gm_adventure_design', [
      'fields' => [
        'id'             => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'    => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'session_id'     => ['type' => 'int',    'unsigned' => TRUE],
        'scene_type'     => ['type' => 'varchar', 'length' => 32,   'not null' => TRUE, 'default' => 'combat'],
        'pc_hooks_json'  => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'spotlight_pc'   => ['type' => 'int',    'unsigned' => TRUE],
        'emotional_beat' => ['type' => 'varchar', 'length' => 128,  'not null' => TRUE, 'default' => ''],
        'created'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'campaign'         => ['campaign_id'],
        'campaign_session' => ['campaign_id', 'session_id'],
      ],
    ]);
  }

  // ── dc_gm_campaign_design ──────────────────────────────────────────────
  if (!$schema->tableExists('dc_gm_campaign_design')) {
    $schema->createTable('dc_gm_campaign_design', [
      'fields' => [
        'id'                   => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
        'campaign_id'          => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'scope'                => ['type' => 'varchar', 'length' => 16,   'not null' => TRUE, 'default' => 'extended'],
        'level_ceiling'        => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 20],
        'downtime_depth'       => ['type' => 'varchar', 'length' => 16,   'not null' => TRUE, 'default' => 'medium'],
        'collaboration_mode'   => ['type' => 'varchar', 'length' => 32,   'not null' => TRUE, 'default' => 'gm_led'],
        'touchstones_json'     => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'character_goals_json' => ['type' => 'text',   'size' => 'big',   'not null' => TRUE, 'default' => '[]'],
        'created'              => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
        'updated'              => ['type' => 'int',    'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign' => ['campaign_id']],
    ]);
  }

  // Import seed reference content.
  /** @var \Drupal\dungeoncrawler_content\Service\GmReferenceService $ref */
  $ref = \Drupal::service('dungeoncrawler_content.gm_reference');
  $seeded = $ref->importSeedCatalog();

  return "Created 11 GM Running Guide tables and seeded {$seeded} GMG reference entries (dc-gmg-running-guide).";
}

/**
 * Implements hook_update_N() for dc-gmg-subsystems.
 *
 * Creates:
 *   dc_subsystem_session — subsystem session state (chase/influence/research/infiltration/etc.)
 *   dc_variant_rule      — per-campaign variant rule feature flags
 */
function dungeoncrawler_content_update_10047() {
  $schema = \Drupal::database()->schema();

  // ── dc_subsystem_session ──────────────────────────────────────────────────
  if (!$schema->tableExists('dc_subsystem_session')) {
    $schema->createTable('dc_subsystem_session', [
      'fields' => [
        'id'             => ['type' => 'serial',  'unsigned' => TRUE,  'not null' => TRUE],
        'campaign_id'    => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
        'subsystem_type' => ['type' => 'varchar',  'length' => 32,      'not null' => TRUE, 'default' => ''],
        'status'         => ['type' => 'varchar',  'length' => 16,      'not null' => TRUE, 'default' => 'active'],
        'progress_state' => ['type' => 'text',     'size' => 'big',     'not null' => TRUE, 'default' => '{}'],
        'initiated_by'   => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
        'created'        => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
        'updated'        => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'indexes' => [
        'campaign'        => ['campaign_id'],
        'campaign_status' => ['campaign_id', 'status'],
        'campaign_type'   => ['campaign_id', 'subsystem_type'],
      ],
    ]);
  }

  // ── dc_variant_rule ───────────────────────────────────────────────────────
  if (!$schema->tableExists('dc_variant_rule')) {
    $schema->createTable('dc_variant_rule', [
      'fields' => [
        'id'          => ['type' => 'serial',  'unsigned' => TRUE,  'not null' => TRUE],
        'campaign_id' => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
        'rule_name'   => ['type' => 'varchar',  'length' => 64,      'not null' => TRUE, 'default' => ''],
        'enabled'     => ['type' => 'int',      'size' => 'tiny',    'not null' => TRUE, 'default' => 0],
        'config_json' => ['type' => 'text',     'size' => 'big',     'not null' => TRUE, 'default' => '{}'],
        'created'     => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
        'updated'     => ['type' => 'int',      'unsigned' => TRUE,  'not null' => TRUE, 'default' => 0],
      ],
      'primary key' => ['id'],
      'unique keys' => ['campaign_rule' => ['campaign_id', 'rule_name']],
      'indexes' => [
        'campaign' => ['campaign_id'],
      ],
    ]);
  }
}
