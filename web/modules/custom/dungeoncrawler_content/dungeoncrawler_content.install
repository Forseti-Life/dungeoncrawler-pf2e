      'player_uids' => ['type' => 'text', 'size' => 'normal', 'not null' => TRUE, 'description' => 'JSON array of player user IDs.'],
      'narrative_state' => ['type' => 'text', 'size' => 'big', 'not null' => TRUE, 'description' => 'JSON: starting narrative state, session summary, and NPC tracking.'],
      'character_state_snapshot' => ['type' => 'text', 'size' => 'big', 'not null' => TRUE, 'description' => 'JSON map of character_id to state committed at session end.'],
      'session_xp' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0, 'description' => 'Total XP granted to the party during this session.'],
      'status' => ['type' => 'varchar', 'length' => 32, 'not null' => TRUE, 'default' => 'active', 'description' => 'Session status: active or ended.'],
      'started_at' => ['type' => 'int', 'not null' => TRUE, 'default' => 0, 'description' => 'Unix timestamp when session started.'],
      'ended_at' => ['type' => 'int', 'not null' => FALSE, 'default' => NULL, 'description' => 'Unix timestamp when session ended (NULL while active).'],
    ],
    'primary key' => ['id'],
    'unique keys' => ['uuid' => ['uuid']],
    'indexes' => [
      'campaign_id' => ['campaign_id'],
      'gm_uid' => ['gm_uid'],
      'status' => ['status'],
      'campaign_status' => ['campaign_id', 'status'],
    ],
  ];

  // DC-RG-01: combat_afflictions (added via update_10036; mirrored here for fresh installs).
  $schema['combat_afflictions'] = [
    'description' => 'Tracks active afflictions (poison, disease, curse) per participant per encounter.',
    'fields' => [
      'id' => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE],
      'encounter_id' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      'participant_id' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      'affliction_type' => ['type' => 'varchar', 'length' => 32, 'not null' => TRUE, 'default' => 'poison'],
      'affliction_name' => ['type' => 'varchar', 'length' => 128, 'not null' => TRUE, 'default' => ''],
      'affliction_level' => ['type' => 'int', 'not null' => TRUE, 'default' => 1],
      'save_type' => ['type' => 'varchar', 'length' => 16, 'not null' => TRUE, 'default' => 'Fortitude'],
      'save_dc' => ['type' => 'int', 'not null' => TRUE, 'default' => 15],
      'current_stage' => ['type' => 'int', 'not null' => TRUE, 'default' => 1],
      'max_stage' => ['type' => 'int', 'not null' => TRUE, 'default' => 3],
      'onset' => ['type' => 'varchar', 'length' => 64, 'not null' => FALSE],
      'onset_elapsed' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0],
      'max_duration' => ['type' => 'int', 'not null' => FALSE],
      'duration_elapsed' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'is_virulent' => ['type' => 'int', 'size' => 'tiny', 'not null' => TRUE, 'default' => 0],
      'consecutive_successes' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'stages_json' => ['type' => 'text', 'size' => 'big', 'not null' => TRUE],
      'status' => ['type' => 'varchar', 'length' => 16, 'not null' => TRUE, 'default' => 'active'],
      'created' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
      'updated' => ['type' => 'int', 'not null' => TRUE, 'default' => 0],
    ],
    'primary key' => ['id'],
    'indexes' => [
      'encounter_participant' => ['encounter_id', 'participant_id'],
      'status' => ['status'],
    ],
  ];

  // DC-RF-01 / DC-RG-01: dc_requirements (update_10034 + feature_id from update_10038).
  $schema['dc_requirements'] = [
    'description' => 'PF2E requirements extracted from rulebooks for implementation tracking.',
    'fields' => [
      'id' => ['type' => 'serial', 'unsigned' => TRUE, 'not null' => TRUE, 'description' => 'Primary key.'],
      'book_id' => ['type' => 'varchar', 'length' => 16, 'not null' => TRUE, 'default' => ''],
      'book_title' => ['type' => 'varchar', 'length' => 128, 'not null' => TRUE, 'default' => ''],
      'chapter_key' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE, 'default' => ''],
      'chapter_title' => ['type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''],
      'section' => ['type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''],
      'paragraph_title' => ['type' => 'varchar', 'length' => 255, 'not null' => TRUE, 'default' => ''],
      'req_text' => ['type' => 'text', 'size' => 'medium', 'not null' => TRUE],
      'req_hash' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE, 'default' => ''],
      'status' => ['type' => 'varchar', 'length' => 32, 'not null' => TRUE, 'default' => 'pending'],
      'source_file' => ['type' => 'varchar', 'length' => 128, 'not null' => TRUE, 'default' => ''],
      'updated_at' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      'updated_by' => ['type' => 'int', 'unsigned' => TRUE, 'not null' => TRUE, 'default' => 0],
      'feature_id' => ['type' => 'varchar', 'length' => 64, 'not null' => TRUE, 'default' => '', 'description' => 'Feature identifier linking requirement to a roadmap feature.'],
    ],
    'primary key' => ['id'],
    'unique keys' => ['req_hash' => ['req_hash']],
    'indexes' => [
      'book_chapter' => ['book_id', 'chapter_key'],
      'status' => ['status'],
      'idx_feature_id' => ['feature_id'],
    ],
  ];

  return $schema;
}

/**
 * Implements hook_install().
 */
function dungeoncrawler_content_install() {
  \Drupal::messenger()->addMessage(t('Dungeon Crawler Content module has been installed.'));

  // Create ancestry content type on fresh installs (mirrors update_10016/10030 for test environments).
  try {
    $type = \Drupal\node\Entity\NodeType::load('ancestry');
    if (!$type) {
      $type = \Drupal\node\Entity\NodeType::create([
        'type' => 'ancestry',
        'name' => 'Ancestry',
        'description' => 'PF2E ancestry definitions (dwarf, elf, gnome, goblin, halfling, human, etc.).',
        'settings' => [
          'node' => [
            'options' => ['status' => TRUE, 'promote' => FALSE, 'sticky' => FALSE, 'revision' => FALSE],
            'preview' => DRUPAL_DISABLED,
            'submitted' => FALSE,
          ],
        ],
      ]);
      $type->save();
      \Drupal::logger('dungeoncrawler_content')->notice('hook_install: created ancestry content type.');
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Ancestry content type creation during install failed: @error', ['@error' => $e->getMessage()]);
  }

  // Create ancestry custom fields on fresh installs (mirrors update_10030).
  try {
    $ancestry_fields = [
      'field_ancestry_hp' => ['type' => 'integer', 'cardinality' => 1, 'label' => 'Hit Points'],
      'field_ancestry_size' => ['type' => 'string', 'cardinality' => 1, 'label' => 'Size', 'settings' => ['max_length' => 20]],
      'field_ancestry_speed' => ['type' => 'integer', 'cardinality' => 1, 'label' => 'Speed'],
      'field_ancestry_boosts' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Ability Boosts', 'settings' => ['max_length' => 50]],
      'field_ancestry_flaws' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Ability Flaws', 'settings' => ['max_length' => 50]],
      'field_ancestry_languages' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Languages', 'settings' => ['max_length' => 50]],
      'field_ancestry_senses' => ['type' => 'string', 'cardinality' => \Drupal\Core\Field\FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED, 'label' => 'Senses', 'settings' => ['max_length' => 50]],
    ];
    foreach ($ancestry_fields as $field_name => $def) {
      if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('node', $field_name)) {
        $storage_def = [
          'field_name' => $field_name,
          'entity_type' => 'node',
          'type' => $def['type'],
          'cardinality' => $def['cardinality'],
        ];
        if (!empty($def['settings'])) {
          $storage_def['settings'] = $def['settings'];
        }
        \Drupal\field\Entity\FieldStorageConfig::create($storage_def)->save();
      }
      if (!\Drupal\field\Entity\FieldConfig::loadByName('node', 'ancestry', $field_name)) {
        \Drupal\field\Entity\FieldConfig::create([
          'field_name' => $field_name,
          'entity_type' => 'node',
          'bundle' => 'ancestry',
          'label' => $def['label'],
          'required' => FALSE,
        ])->save();
      }
    }
    \Drupal::logger('dungeoncrawler_content')->notice('hook_install: created ancestry custom fields.');
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Ancestry field creation during install failed: @error', ['@error' => $e->getMessage()]);
  }

  // Seed 6 core ancestry nodes on fresh installs (mirrors update_10016).
  try {
    $core_ancestries = ['Human', 'Elf', 'Dwarf', 'Gnome', 'Goblin', 'Halfling'];
    $all_ancestries = \Drupal\dungeoncrawler_content\Service\CharacterManager::ANCESTRIES;
    foreach ($core_ancestries as $ancestry_name) {
      if (!isset($all_ancestries[$ancestry_name])) {
        continue;
      }
      $existing = \Drupal::entityQuery('node')
        ->condition('type', 'ancestry')
        ->condition('title', $ancestry_name)
        ->accessCheck(FALSE)
        ->execute();
      if (!empty($existing)) {
        continue;
      }
      $data = $all_ancestries[$ancestry_name];
      $node = \Drupal\node\Entity\Node::create([
        'type'   => 'ancestry',
        'title'  => $ancestry_name,
        'status' => 1,
        'uid'    => 1,
        'body'   => [
          'value'  => json_encode([
            'hp'        => $data['hp'],
            'size'      => $data['size'],
            'speed'     => $data['speed'],
            'boosts'    => $data['boosts'],
            'flaw'      => $data['flaw'] ?? null,
            'languages' => $data['languages'],
            'senses'    => $data['vision'],
            'traits'    => $data['traits'],
          ], JSON_PRETTY_PRINT),
          'format' => 'plain_text',
        ],
      ]);
      $node->set('field_ancestry_hp', (int) ($data['hp'] ?? 0));
      $node->set('field_ancestry_size', $data['size'] ?? 'Medium');
      $node->set('field_ancestry_speed', (int) ($data['speed'] ?? 25));
      $node->set('field_ancestry_boosts', array_map(fn($b) => ['value' => $b], $data['boosts'] ?? []));
      $node->set('field_ancestry_flaws', array_map(fn($f) => ['value' => $f], array_filter([$data['flaw'] ?? ''])));
      $node->set('field_ancestry_languages', array_map(fn($l) => ['value' => $l], $data['languages'] ?? []));
      $node->set('field_ancestry_senses', !empty($data['vision']) ? [['value' => $data['vision']]] : []);
      $node->save();
    }
    \Drupal::logger('dungeoncrawler_content')->notice('hook_install: seeded core ancestry nodes.');
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Ancestry node seeding during install failed: @error', ['@error' => $e->getMessage()]);
  }

  // Seed all content from JSON files (items, creatures, etc.).
  try {
    /** @var \Drupal\dungeoncrawler_content\Service\ContentRegistry $registry */
    $registry = \Drupal::service('dungeoncrawler_content.content_registry');
    $count = $registry->importContentFromJson();
    \Drupal::messenger()->addMessage(t('Imported @count content items from JSON files.', ['@count' => $count]));
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Content import during install failed: @error', ['@error' => $e->getMessage()]);
  }

  // Seed template libraries (setting/room templates, encounters, loot, etc.).
  try {
    /** @var \Drupal\dungeoncrawler_content\Service\ContentSeederService $seeder */
    $seeder = \Drupal::service('dungeoncrawler_content.content_seeder');
    $summary = $seeder->seedAll();
    $total = array_sum($summary);
    \Drupal::messenger()->addMessage(t('Seeded @count template/content records from packaged JSON.', ['@count' => $total]));
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Content seeder during install failed: @error', ['@error' => $e->getMessage()]);
  }
}

/**
 * Implements hook_uninstall().
 */
function dungeoncrawler_content_uninstall() {
  \Drupal::messenger()->addMessage(t('Dungeon Crawler Content module has been uninstalled.'));
}

/**
 * Add dc_characters table for PF2e character storage.
 */
function dungeoncrawler_content_update_10001() {
  $schema = dungeoncrawler_content_schema();
  $database = \Drupal::database();
  
  try {
    if (!$database->schema()->tableExists('dc_characters')) {
      $database->schema()->createTable('dc_characters', $schema['dc_characters']);
      return t('Created dc_characters table.');
    }
    return t('dc_characters table already exists.');
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10001 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to create dc_characters table: ' . $e->getMessage());
  }
}

/**
 * Add game content system tables.
 */
function dungeoncrawler_content_update_10002() {
  $schema = dungeoncrawler_content_schema();
  $database = \Drupal::database();
  $messages = [];

  try {
    if (!$database->schema()->tableExists('dungeoncrawler_content_registry')) {
      $database->schema()->createTable('dungeoncrawler_content_registry', $schema['dungeoncrawler_content_registry']);
      $messages[] = 'Created dungeoncrawler_content_registry table.';
    }

    if (!$database->schema()->tableExists('dungeoncrawler_content_loot_tables')) {
      $database->schema()->createTable('dungeoncrawler_content_loot_tables', $schema['dungeoncrawler_content_loot_tables']);
      $messages[] = 'Created dungeoncrawler_content_loot_tables table.';
    }

    if (!$database->schema()->tableExists('dungeoncrawler_content_encounter_templates')) {
      $database->schema()->createTable('dungeoncrawler_content_encounter_templates', $schema['dungeoncrawler_content_encounter_templates']);
      $messages[] = 'Created dungeoncrawler_content_encounter_templates table.';
    }

    if (empty($messages)) {
      return t('Game content system tables already exist.');
    }

    return t('Game content system update complete: @messages', ['@messages' => implode(' ', $messages)]);
  }
  catch (\Exception $e) {
    \Drupal::logger('dungeoncrawler_content')->error('Update 10002 failed: @error', ['@error' => $e->getMessage()]);
    throw new \Drupal\Core\Utility\UpdateException('Failed to create game content system tables: ' . $e->getMessage());
  }
}

