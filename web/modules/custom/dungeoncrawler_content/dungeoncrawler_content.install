      'narrative_state' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => TRUE,
        'description' => 'JSON: starting narrative state, session summary, and NPC tracking.',
      ],
      'character_state_snapshot' => [
        'type' => 'text',
        'size' => 'big',
        'not null' => TRUE,
        'description' => 'JSON map of character_id → {xp, hp, conditions, inventory} committed at session end.',
      ],
      'session_xp' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Total XP granted to the party during this session.',
      ],
      'status' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'default' => 'active',
        'description' => 'Session status: active or ended.',
      ],
      'started_at' => [
        'type' => 'int',
        'not null' => TRUE,
        'default' => 0,
        'description' => 'Unix timestamp when session started.',
      ],
      'ended_at' => [
        'type' => 'int',
        'not null' => FALSE,
        'default' => NULL,
        'description' => 'Unix timestamp when session ended (NULL while active).',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'uuid' => ['uuid'],
    ],
    'indexes' => [
      'campaign_id' => ['campaign_id'],
      'gm_uid' => ['gm_uid'],
      'status' => ['status'],
      'campaign_status' => ['campaign_id', 'status'],
    ],
  ]);

  return 'Created dc_sessions table for play session tracking (dc-cr-session-structure).';
}

/**
 * Add feature_id column and idx_feature_id index to dc_requirements (DC-RF-01).
 *
 * Idempotent: skips addField/addIndex if already present (e.g. production
 * where the column was applied via direct ALTER TABLE in ca45aa0e0).
 */
function dungeoncrawler_content_update_10038() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('dc_requirements')) {
    return 'dc_requirements table does not exist — skipped.';
  }

  if (!$schema->fieldExists('dc_requirements', 'feature_id')) {
    $schema->addField('dc_requirements', 'feature_id', [
      'type' => 'varchar',
      'length' => 64,
      'not null' => TRUE,
      'default' => '',
      'description' => 'Feature identifier linking requirement to a roadmap feature.',
    ]);
  }

  // Add index if not already present. Drupal schema API has no indexExists();
  // wrap in try/catch to stay idempotent on production where it may exist.
  try {
    $schema->addIndex('dc_requirements', 'idx_feature_id', ['feature_id'], [
      'fields' => [
        'feature_id' => [
          'type' => 'varchar',
          'length' => 64,
          'not null' => TRUE,
          'default' => '',
        ],
      ],
    ]);
  }
  catch (\Exception $e) {
    // Index already exists on this install; ignore.
  }

  return 'Added feature_id column (and idx_feature_id index) to dc_requirements (DC-RF-01).';
}

