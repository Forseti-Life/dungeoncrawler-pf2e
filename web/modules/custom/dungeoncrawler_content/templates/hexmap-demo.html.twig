{#
/**
 * @file
 * Template for the hex map demo page.
 *
 * Available variables:
 * - launch_context: Optional campaign/dungeon launch context from tavern flow.
 * - dungeon_payload: Optional room/entity payload from example level.
 */
#}

  <div class="hexmap-container" id="hexmap-container"{% if is_admin %} data-admin="1"{% endif %}>
  <div class="hexmap-header">
    <div class="hexmap-header__top">
      <div>
        <h1>{{ 'Hex Map Demo'|t }}</h1>
        <p>{{ 'Interactive hexagonal grid powered by PixiJS'|t }}</p>
      </div>
      <div class="hexmap-header__actions">
        {% if is_admin %}
        <button id="debug-panel-toggle" class="btn btn-icon btn--debug-toggle" title="{{ 'Toggle dev panels'|t }}" aria-pressed="false">{{ '🛠'|t }}</button>
        {% endif %}
        <button id="sidebar-drawer-toggle" class="btn btn-icon btn--drawer-toggle" title="{{ 'Toggle sidebar'|t }}" aria-expanded="true" aria-controls="game-layout">{{ '⟩'|t }}</button>
        <button id="fullscreen-toggle" class="btn btn-icon" title="{{ 'Enter fullscreen'|t }}">{{ '⛶'|t }}</button>
      </div>
    </div>
    
    <div class="hexmap-controls hexmap-debug-panel">
      <div class="control-group control-group--config">
        <label class="control-group__title">{{ 'Map Size:'|t }}</label>
        <select id="grid-size">
          <option value="small">{{ 'Small (10x10)'|t }}</option>
          <option value="medium" selected>{{ 'Medium (20x20)'|t }}</option>
          <option value="large">{{ 'Large (40x40)'|t }}</option>
        </select>
      </div>
      
      <div class="control-group control-group--config">
        <label class="control-group__title">{{ 'Zoom Baseline:'|t }}</label>
        <input type="range" id="hex-size" min="20" max="60" value="30" />
        <span id="hex-size-value">30px</span>
      </div>
      
      <div class="control-group control-group--view">
        <label class="control-group__title">{{ 'View:'|t }}</label>
        <button id="toggle-coordinates" class="btn">{{ 'Toggle Coordinates'|t }}</button>
        <button id="toggle-grid" class="btn">{{ 'Toggle Grid Lines'|t }}</button>
        <button id="toggle-fog" class="btn">{{ 'Toggle Fog of War'|t }}</button>
        <button id="reset-view" class="btn">{{ 'Reset View'|t }}</button>
      </div>
    </div>
    
  </div>

  <div class="game-layout-controls">
    <label class="layout-ratio-label" for="layout-ratio-slider">
      <span class="layout-ratio-label__text">{{ 'Layout'|t }}</span>
      <span class="layout-ratio-label__icons">
        <span title="{{ 'Board'|t }}">&#x1F5FA;</span>
        <input type="range" id="layout-ratio-slider" min="15" max="50" value="20" step="1" />
        <span title="{{ 'Sheet'|t }}">&#x1F4DC;</span>
      </span>
      <span id="layout-ratio-value" class="layout-ratio-label__value">80 / 20</span>
    </label>
  </div>

  <div class="game-layout" id="game-layout">
  <div class="game-layout__main">

  <div class="hexmap-stage">
    <div id="hexmap-canvas-container" class="hexmap-canvas-wrapper">
      <!-- PixiJS canvas will be inserted here -->

      {# Game Coordinator — AI GM Narration Overlay #}
      <div id="narration-overlay" class="narration-overlay">
        <div class="narration-overlay__text" id="narration-text"></div>
        <div class="narration-overlay__skip" id="narration-skip">{{ 'Click to continue'|t }}</div>
      </div>

      {# Game Coordinator — Phase Indicator Badge #}
      <div id="game-phase-indicator" class="phase-indicator phase-exploration" style="display:none;">
        {{ 'Exploration'|t }}
      </div>

      {# Game Coordinator — Exploration Actions Panel #}
      <div id="exploration-actions" class="exploration-actions" style="display:none;">
        <div class="exploration-actions__header">
          <h4>{{ 'Actions'|t }}</h4>
        </div>
        <div class="exploration-actions__buttons">
          <button id="action-move" class="btn btn-action" data-action="move">{{ '🚶 Move'|t }}</button>
          <button id="action-interact" class="btn btn-action" data-action="interact">{{ '🤝 Interact'|t }}</button>
          <button id="action-talk" class="btn btn-action" data-action="talk">{{ '💬 Talk'|t }}</button>
          <button id="action-search" class="btn btn-action" data-action="search">{{ '🔍 Search'|t }}</button>
          <button id="action-rest" class="btn btn-action" data-action="rest">{{ '🛌 Rest'|t }}</button>
        </div>
      </div>

      {# Encounter-mode action buttons (managed by GameCoordinator) #}
      <div id="encounter-actions" class="encounter-actions" style="display:none;">
        <button id="action-attack" class="btn btn-action btn-action--attack" data-action="attack">{{ '⚔️ Strike'|t }}</button>
        <button id="end-turn" class="btn btn-action btn-action--end" data-action="end_turn">{{ '⏭️ End Turn'|t }}</button>
      </div>

      <div id="turn-hud" class="turn-hud dc-is-hidden">
        <div class="turn-hud__row">
          <span id="turn-owner" class="pill pill-strong">{{ 'No active combat'|t }}</span>
          <span id="current-round" class="pill pill-round">{{ 'Round 0'|t }}</span>
        </div>

        <div id="current-turn" class="turn-hud__name">{{ 'No active turn'|t }}</div>

        <div class="turn-hud__meta">
          <span id="turn-action-summary" class="chip chip-strong">{{ 'Actions: -'|t }}</span>
          <span id="turn-move-summary" class="chip">{{ 'Movement: -'|t }}</span>
          <span id="turn-reaction" class="chip chip-ghost">{{ 'Reaction: ready'|t }}</span>
        </div>

        <div id="turn-action-chips" class="turn-hud__actions">
          <span class="chip chip-ghost">{{ 'Move'|t }}</span>
          <span class="chip chip-ghost">{{ 'Strike'|t }}</span>
          <span class="chip chip-ghost">{{ 'Cast / Skill'|t }}</span>
          <span class="chip chip-end">{{ 'End Turn'|t }}</span>
        </div>

        <div id="combat-controls" class="turn-hud__controls">
          <button id="start-combat" class="btn btn-success">{{ '⚔️ Start Combat'|t }}</button>
          <button id="end-combat" class="btn btn-warning dc-is-hidden">{{ '🛑 End Combat'|t }}</button>
        </div>

        <div id="initiative-tracker" class="initiative-tracker dc-is-hidden">
          <div class="tracker-header">
            <h4>{{ 'Initiative Order'|t }}</h4>
          </div>
          <div class="initiative-list" id="initiative-list">
            <!-- Initiative order will be populated here -->
          </div>
        </div>
      </div>
    </div>

    <div class="hexmap-chat" id="hexmap-chat">
      <div class="hexmap-chat__header">
        <h3 id="chat-panel-title">{{ 'Room Dialogue'|t }}</h3>
        <span class="chip chip-live" id="chat-status">{{ 'Open'|t }}</span>
        <button id="chat-maximize-toggle" class="btn btn-icon btn--chat-maximize-toggle" title="{{ 'Maximize chat'|t }}" aria-pressed="false">{{ '⛶'|t }}</button>
        <button id="chat-dock-toggle" class="btn btn-icon btn--chat-dock-toggle" title="{{ 'Collapse chat'|t }}" aria-expanded="true">{{ '▾'|t }}</button>
      </div>
      {# Session view tabs — top-level navigation between chat views #}
      <div class="hexmap-chat__session-tabs" id="chat-session-tabs">
        <button class="session-view-tab session-view-tab--active" data-view="room" title="Room dialogue &amp; NPC channels">
          <span class="session-view-tab__icon">&#x1F4E2;</span>{{ 'Room'|t }}
        </button>
        <button class="session-view-tab" data-view="narrative" title="Your character's perception-filtered story">
          <span class="session-view-tab__icon">&#x1F4D6;</span>{{ 'My Story'|t }}
        </button>
        <button class="session-view-tab" data-view="party" title="Party-only huddle chat">
          <span class="session-view-tab__icon">&#x1F6E1;</span>{{ 'Party'|t }}
        </button>
        <button class="session-view-tab" data-view="gm-private" title="Secret actions only the GM sees">
          <span class="session-view-tab__icon">&#x1F575;</span>{{ 'GM Secret'|t }}
        </button>
        <button class="session-view-tab" data-view="system-log" title="Dice rolls, checks &amp; mechanical results">
          <span class="session-view-tab__icon">&#x1F3B2;</span>{{ 'Dice Log'|t }}
        </button>
      </div>
      {# Channel sub-tabs — visible only in Room view #}
      <div class="hexmap-chat__channels" id="chat-channel-tabs">
        <button class="chat-channel-tab chat-channel-tab--active" data-channel="room" title="Main room channel">{{ 'Room'|t }}</button>
      </div>
      <div class="hexmap-chat__channel-indicator" id="chat-channel-indicator" data-channel-type="room">
        <span class="channel-indicator__icon">&#x1F4E2;</span>
        <span class="channel-indicator__label" id="chat-channel-label">{{ 'Room — Everyone can hear'|t }}</span>
      </div>
      <div class="hexmap-chat__log" id="chat-log" aria-live="polite" data-channel-type="room">
        <div class="chat-line chat-line--system">{{ 'You are in a quiet room. Try saying hello.'|t }}</div>
      </div>
      <form class="hexmap-chat__input" id="chat-form">
        <input id="chat-input" type="text" placeholder="{{ 'Say something to the room...'|t }}" autocomplete="off" />
        <button id="chat-send" class="btn btn-primary" type="submit">{{ 'Send'|t }}</button>
      </form>
    </div>

  </div>

  </div>{# /.game-layout__main #}
  <div class="game-layout__sidebar">

  {# Sidebar Tab Bar #}
  <div class="sidebar-tabs" id="sidebar-tabs">
    <button class="sidebar-tab sidebar-tab--active" data-panel="character">
      <span class="sidebar-tab__icon">&#x1F4DC;</span>{{ 'Character'|t }}
    </button>
    <button class="sidebar-tab" data-panel="inventory">
      <span class="sidebar-tab__icon">&#x1F392;</span>{{ 'Inventory'|t }}
    </button>
    <button class="sidebar-tab" data-panel="quests">
      <span class="sidebar-tab__icon">&#x1F3AF;</span>{{ 'Quests'|t }}
    </button>
    <button class="sidebar-tab" data-panel="inspector">
      <span class="sidebar-tab__icon">&#x1F50E;</span>{{ 'Inspector'|t }}
    </button>
  </div>

  {# === Character Tab Panel === #}
  <div class="sidebar-panel sidebar-panel--active" id="sidebar-panel-character">
  <div class="character-sheet">
    <div class="character-sheet__header">
      <div class="character-sheet__portrait" id="char-portrait-wrap" style="display:none;">
        <img id="char-portrait" src="" alt="" class="character-sheet__portrait-img" />
      </div>
      <div class="character-sheet__header-info">
        <p class="eyebrow">{{ 'Character Sheet'|t }} <a id="char-full-sheet-link" href="#" class="full-sheet-link" style="display:none;" target="_blank">{{ 'View Full Sheet ↗'|t }}</a></p>
        <h2 id="char-name">{{ 'Select a character'|t }}</h2>
        <p id="char-type" class="muted">{{ 'Type —'|t }}</p>
        <p id="char-subtitle" class="muted small" style="display:none;"></p>
      </div>
      <div class="character-badges">
        <span id="char-ancestry" class="pill pill-muted">{{ 'Ancestry —'|t }}</span>
        <span id="char-level" class="pill pill-strong">{{ 'Lvl —'|t }}</span>
      </div>
    </div>

    <div id="char-sheet-embed-wrap" class="character-sheet__embed-wrap" style="display:none;">
      <iframe
        id="char-sheet-embed"
        class="character-sheet__embed"
        title="{{ 'Full Character Sheet'|t }}"
        loading="lazy"
        referrerpolicy="same-origin"></iframe>
    </div>

    <div id="char-sheet-legacy">

    <div class="character-sheet__core-stats">
      <div class="stat-card">
        <p class="label">{{ 'HP'|t }}</p>
        <p id="char-hp" class="stat-value">-</p>
      </div>
      <div class="stat-card">
        <p class="label">{{ 'AC'|t }}</p>
        <p id="char-ac" class="stat-value">-</p>
      </div>
      <div class="stat-card">
        <p class="label">{{ 'Hero'|t }}</p>
        <p id="char-hero" class="stat-value">-</p>
      </div>
      <div class="stat-card">
        <p class="label">{{ 'Speed'|t }}</p>
        <p id="char-speed" class="stat-value">-</p>
      </div>
    </div>

    <div class="character-sheet__core-stats character-sheet__core-stats--secondary">
      <div class="stat-card stat-card--small">
        <p class="label">{{ 'Perception'|t }}</p>
        <p id="char-perception" class="stat-value">+0</p>
      </div>
      <div class="stat-card stat-card--small">
        <p class="label">{{ 'XP'|t }}</p>
        <p id="char-xp" class="stat-value">-</p>
      </div>
    </div>

    <div class="character-sheet__section">
      <div class="section-header" data-section="abilities">
        <h4>{{ 'Abilities'|t }}</h4>
        <span class="section-toggle">▾</span>
      </div>
      <div class="section-body" data-section="abilities">
        <div class="ability-scores">
          <div class="ability-score">
            <span class="ability-label">{{ 'STR'|t }}</span>
            <span id="char-str" class="ability-value">10</span>
            <span id="char-str-mod" class="ability-mod">+0</span>
          </div>
          <div class="ability-score">
            <span class="ability-label">{{ 'DEX'|t }}</span>
            <span id="char-dex" class="ability-value">10</span>
            <span id="char-dex-mod" class="ability-mod">+0</span>
          </div>
          <div class="ability-score">
            <span class="ability-label">{{ 'CON'|t }}</span>
            <span id="char-con" class="ability-value">10</span>
            <span id="char-con-mod" class="ability-mod">+0</span>
          </div>
          <div class="ability-score">
            <span class="ability-label">{{ 'INT'|t }}</span>
            <span id="char-int" class="ability-value">10</span>
            <span id="char-int-mod" class="ability-mod">+0</span>
          </div>
          <div class="ability-score">
            <span class="ability-label">{{ 'WIS'|t }}</span>
            <span id="char-wis" class="ability-value">10</span>
            <span id="char-wis-mod" class="ability-mod">+0</span>
          </div>
          <div class="ability-score">
            <span class="ability-label">{{ 'CHA'|t }}</span>
            <span id="char-cha" class="ability-value">10</span>
            <span id="char-cha-mod" class="ability-mod">+0</span>
          </div>
        </div>
      </div>
    </div>

    <div class="character-sheet__section">
      <div class="section-header" data-section="saves">
        <h4>{{ 'Saving Throws'|t }}</h4>
        <span class="section-toggle">▾</span>
      </div>
      <div class="section-body" data-section="saves">
        <div class="saves-grid">
          <div class="save-item">
            <span class="save-label">{{ 'Fort'|t }}</span>
            <span id="char-fort" class="save-value">+0</span>
          </div>
          <div class="save-item">
            <span class="save-label">{{ 'Ref'|t }}</span>
            <span id="char-ref" class="save-value">+0</span>
          </div>
          <div class="save-item">
            <span class="save-label">{{ 'Will'|t }}</span>
            <span id="char-will" class="save-value">+0</span>
          </div>
        </div>
      </div>
    </div>

    <div class="character-sheet__section collapsed">
      <div class="section-header" data-section="skills">
        <h4>{{ 'Skills'|t }}</h4>
        <span class="section-toggle">▸</span>
      </div>
      <div class="section-body dc-is-hidden" data-section="skills">
        <ul id="char-skills" class="skills-list">
          <li class="skills-empty">{{ 'No skills loaded'|t }}</li>
        </ul>
      </div>
    </div>

    <div class="character-sheet__section">
      <div class="section-header" data-section="conditions">
        <h4>{{ 'Conditions'|t }}</h4>
        <span class="section-toggle">▾</span>
      </div>
      <div class="section-body" data-section="conditions">
        <ul id="char-conditions" class="conditions-list">
          <li class="conditions-empty">{{ 'None'|t }}</li>
        </ul>
      </div>
    </div>

    <div class="character-sheet__section collapsed">
      <div class="section-header" data-section="inventory">
        <h4>{{ 'Inventory'|t }}</h4>
        <span class="section-toggle">▸</span>
      </div>
      <div class="section-body dc-is-hidden" data-section="inventory">
        <div id="char-currency" class="currency-display">
          <span class="currency-item"><span class="currency-label">{{ 'GP:'|t }}</span> <span id="char-gp">0</span></span>
          <span class="currency-item"><span class="currency-label">{{ 'SP:'|t }}</span> <span id="char-sp">0</span></span>
          <span class="currency-item"><span class="currency-label">{{ 'CP:'|t }}</span> <span id="char-cp">0</span></span>
        </div>
        <ul id="char-inventory" class="inventory-list">
          <li class="inventory-empty">{{ 'No items'|t }}</li>
        </ul>
      </div>
    </div>

    <div class="character-sheet__section collapsed">
      <div class="section-header" data-section="features">
        <h4>{{ 'Features & Feats'|t }}</h4>
        <span class="section-toggle">▸</span>
      </div>
      <div class="section-body dc-is-hidden" data-section="features">
        <ul id="char-features" class="features-list">
          <li class="features-empty">{{ 'No features loaded'|t }}</li>
        </ul>
      </div>
    </div>

    <div class="character-sheet__section collapsed" id="char-spells-section" style="display:none;">
      <div class="section-header" data-section="spells">
        <h4>{{ 'Spellcasting'|t }}</h4>
        <span class="section-toggle">▸</span>
      </div>
      <div class="section-body dc-is-hidden" data-section="spells">
        <div id="char-spell-meta" class="spell-meta"></div>
        <ul id="char-spells" class="spells-list">
          <li class="spells-empty">{{ 'No spells'|t }}</li>
        </ul>
      </div>
    </div>
    </div>
  </div>
  </div>{# /.sidebar-panel-character #}

  {# === Inventory Tab Panel === #}
  <div class="sidebar-panel" id="sidebar-panel-inventory" style="display:none;">
    <div class="inventory-panel">
      <div class="inventory-panel__header">
        <h3>{{ 'Inventory'|t }}</h3>
        <div class="inventory-panel__weight">
          <span class="label">{{ 'Bulk:'|t }}</span>
          <span id="inv-bulk-current" class="inventory-bulk-value">0</span>
          <span class="muted">/</span>
          <span id="inv-bulk-max" class="inventory-bulk-value">5</span>
        </div>
      </div>

      <div class="inventory-panel__currency">
        <div class="currency-coin currency-coin--gp">
          <span class="currency-coin__icon">&#x1FA99;</span>
          <span id="inv-gp" class="currency-coin__amount">0</span>
          <span class="currency-coin__label">{{ 'GP'|t }}</span>
        </div>
        <div class="currency-coin currency-coin--sp">
          <span class="currency-coin__icon">&#x26AA;</span>
          <span id="inv-sp" class="currency-coin__amount">0</span>
          <span class="currency-coin__label">{{ 'SP'|t }}</span>
        </div>
        <div class="currency-coin currency-coin--cp">
          <span class="currency-coin__icon">&#x1F7E4;</span>
          <span id="inv-cp" class="currency-coin__amount">0</span>
          <span class="currency-coin__label">{{ 'CP'|t }}</span>
        </div>
      </div>

      <div class="inventory-panel__filters">
        <button class="inv-filter inv-filter--active" data-filter="all">{{ 'All'|t }}</button>
        <button class="inv-filter" data-filter="weapon">{{ '⚔️ Weapons'|t }}</button>
        <button class="inv-filter" data-filter="armor">{{ '🛡️ Armor'|t }}</button>
        <button class="inv-filter" data-filter="consumable">{{ '🧪 Consumables'|t }}</button>
        <button class="inv-filter" data-filter="utility">{{ '🧰 Utility'|t }}</button>
        <button class="inv-filter" data-filter="misc">{{ '🦴 Misc'|t }}</button>
      </div>

      <ul class="inventory-panel__list" id="inv-item-list">
        <li class="inventory-panel__empty">{{ 'No items in inventory'|t }}</li>
      </ul>
    </div>
  </div>{# /.sidebar-panel-inventory #}

  {# === Quests Tab Panel === #}
  <div class="sidebar-panel" id="sidebar-panel-quests" style="display:none;">
    <div class="hexmap-quest-journal hexmap-quest-journal--sidebar" id="quest-journal">
      <div class="hexmap-quest-journal__header">
        <h3>{{ 'Quest Journal'|t }}</h3>
        <span class="chip chip-strong" id="quest-count">0</span>
      </div>
      <ul class="hexmap-quest-journal__list" id="quest-list">
        <li class="quest-empty">{{ 'No active quests'|t }}</li>
      </ul>

      <div class="quest-confirmations" id="quest-confirmations">
        <div class="quest-confirmations__header">
          <h4>{{ 'Pending Confirmations'|t }}</h4>
          <span class="chip chip-strong" id="quest-confirmation-count">0</span>
        </div>
        <ul class="quest-confirmations__list" id="quest-confirmation-list">
          <li class="quest-empty">{{ 'No pending confirmations'|t }}</li>
        </ul>
      </div>
    </div>
  </div>{# /.sidebar-panel-quests #}

  {# === Inspector Tab Panel === #}
  <div class="sidebar-panel" id="sidebar-panel-inspector" style="display:none;">
    <p class="inspector-placeholder muted" id="inspector-placeholder">{{ 'Select an entity on the map to inspect it.'|t }}</p>
    {# entity-info-panel is managed by UIManager.showEntityInfo / hideEntityInfo #}
    <div class="info-panel dc-is-hidden" id="entity-info-panel">
      <h3>{{ 'Selected Entity'|t }}</h3>
      <div class="info-content">
        <div class="entity-inspect-media dc-is-hidden" id="entity-image-wrap">
          <img id="entity-image" src="" alt="" loading="lazy">
        </div>
        <p><strong>{{ 'Name:'|t }}</strong> <span id="entity-name">-</span></p>
        <p><strong>{{ 'Type:'|t }}</strong> <span id="entity-type">-</span></p>
        <p><strong>{{ 'Summary:'|t }}</strong> <span id="entity-summary">-</span></p>
        <p><strong>{{ 'Team:'|t }}</strong> <span id="entity-team">-</span></p>
        <p><strong>{{ 'HP:'|t }}</strong> <span id="entity-hp">-</span></p>
        <p><strong>{{ 'AC:'|t }}</strong> <span id="entity-ac">-</span></p>
        <p><strong>{{ 'Actions:'|t }}</strong> <span id="entity-actions">-</span></p>
        <p><strong>{{ 'Movement:'|t }}</strong> <span id="entity-movement">-</span></p>
        <p><strong>{{ 'Description:'|t }}</strong> <span id="entity-description">-</span></p>
        <div class="entity-known-block">
          <strong>{{ 'Known Details:'|t }}</strong>
          <ul id="entity-known-details" class="entity-known-list">
            <li>{{ 'No additional details are known yet.'|t }}</li>
          </ul>
        </div>
      </div>
    </div>
  </div>{# /.sidebar-panel-inspector #}

  </div>{# /.game-layout__sidebar #}
  </div>{# /.game-layout #}

  <div class="dungeon-state hexmap-debug-panel" id="dungeon-state">
    <div class="dungeon-state__header">
      <h3>{{ 'Dungeon Objects & JSON State'|t }}</h3>
      <p id="dungeon-state-summary" class="muted">{{ 'Loading dungeon state…'|t }}</p>
