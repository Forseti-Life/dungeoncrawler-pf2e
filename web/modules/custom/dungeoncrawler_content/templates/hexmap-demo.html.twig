  <script>
  /* Safe Drupal.t() fallback for inline scripts that run before drupal.js loads */
  var _dt = typeof Drupal !== 'undefined' ? Drupal.t.bind(Drupal) : function(s) { return s; };
  (function () {
    const STORAGE_KEY = 'dc_layout_ratio';
    const slider = document.getElementById('layout-ratio-slider');
    const label  = document.getElementById('layout-ratio-value');
    const layout = document.getElementById('game-layout');
    if (!slider || !layout) return;

    function apply(pct) {
      layout.style.setProperty('--sidebar-pct', pct);
      label.textContent = (100 - pct) + ' / ' + pct;
    }

    // Restore saved preference
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const v = parseInt(saved, 10);
      if (v >= 15 && v <= 50) {
        slider.value = v;
        apply(v);
      }
    }

    slider.addEventListener('input', function () {
      const v = parseInt(this.value, 10);
      apply(v);
    });

    slider.addEventListener('change', function () {
      localStorage.setItem(STORAGE_KEY, this.value);
    });
  })();

  /* ---- Debug Panel Toggle (admin only) ---- */
  (function () {
    const btn = document.getElementById('debug-panel-toggle');
    if (!btn) return;
    const container = document.getElementById('hexmap-container');
    const DEBUG_KEY = 'dc_debug_mode';
    const CSS_CLASS = 'hexmap-debug-active';

    function setDebugMode(on) {
      if (on) {
        container.classList.add(CSS_CLASS);
        btn.setAttribute('aria-pressed', 'true');
        btn.title = _dt('Hide dev panels');
      } else {
        container.classList.remove(CSS_CLASS);
        btn.setAttribute('aria-pressed', 'false');
        btn.title = _dt('Show dev panels');
      }
      localStorage.setItem(DEBUG_KEY, on ? '1' : '0');
    }

    // Restore saved debug preference
    const savedDebug = localStorage.getItem(DEBUG_KEY);
    if (savedDebug === '1') {
      setDebugMode(true);
    }

    btn.addEventListener('click', function () {
      setDebugMode(!container.classList.contains(CSS_CLASS));
    });
  })();

  /* ---- Sidebar Tab Switching ---- */
  (function () {
    const tabBar = document.getElementById('sidebar-tabs');
    if (!tabBar) return;
    const tabs = tabBar.querySelectorAll('.sidebar-tab');
    const TAB_KEY = 'dc_sidebar_tab';

    function activate(panelId) {
      tabs.forEach(function (t) {
        t.classList.toggle('sidebar-tab--active', t.dataset.panel === panelId);
      });
      document.querySelectorAll('.sidebar-panel').forEach(function (p) {
        var id = p.id.replace('sidebar-panel-', '');
        if (id === panelId) {
          p.style.display = '';
          p.classList.add('sidebar-panel--active');
        } else {
          p.style.display = 'none';
          p.classList.remove('sidebar-panel--active');
        }
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var panel = this.dataset.panel;
        activate(panel);
        localStorage.setItem(TAB_KEY, panel);
        // Sync inventory when switching to it
        if (panel === 'inventory') syncInventory();
      });
    });

    // Restore saved tab
    var saved = localStorage.getItem(TAB_KEY);
    if (saved && document.getElementById('sidebar-panel-' + saved)) {
      activate(saved);
    }

