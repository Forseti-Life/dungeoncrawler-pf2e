{#
/**
 * @file
 * Unified schema-driven character creation step template
 *
 * Variables:
 * - character_id: Character ID (or NULL for new character)
 * - character: Character data array
 * - step: Current step number (1-8)
 * - schema: Full schema object for this step
 * - options: Options data (ancestries, classes, etc.)
 * - step_name: Human-readable step name
 * - step_description: Step description text
 * - tips: Array of helpful tips
 */
#}
<div class="character-creation-step step-{{ step }}">
  <div class="creation-container">
    
    {# Progress Bar #}
    <div class="progress-bar">
      <div class="progress-indicator progress-step-{{ step }}"></div>
    </div>
    <div class="progress-text">Step {{ step }} of 8: {{ step_name }}</div>

    {# Main Content #}
    <div class="step-content">
      <h2>{{ step_name }}</h2>
      <p class="step-description">{{ step_description }}</p>

      {# Tips Section #}
      {% if tips %}
        <div class="tips-section">
          <details>
            <summary>💡 Helpful Tips</summary>
            <ul class="tips-list">
              {% for tip in tips %}
                <li>{{ tip }}</li>
              {% endfor %}
            </ul>
          </details>
        </div>
      {% endif %}

      {# Dynamic Form - Rendered via JavaScript from schema #}
      <form id="stepForm" method="post" action="/characters/create/step/{{ step }}/save" data-step="{{ step }}">
        <input type="hidden" name="character_id" value="{{ character_id }}">
        {% if campaign_id %}
          <input type="hidden" name="campaign_id" value="{{ campaign_id }}">
        {% endif %}
        
        <div id="formFields" class="form-fields">
          {# Fields will be dynamically generated by JavaScript based on schema #}
        </div>

        {# Navigation Buttons #}
        <div class="button-group">
          {% if step > 1 %}
            <a href="/characters/create/step/{{ step - 1 }}?character_id={{ character_id }}{% if campaign_id %}&campaign_id={{ campaign_id }}{% endif %}" class="btn btn-secondary">← Back</a>
          {% else %}
            <a href="/characters{% if campaign_id %}?campaign_id={{ campaign_id }}{% endif %}" class="btn btn-secondary">Cancel</a>
          {% endif %}
          
          {% if step < 8 %}
            <button type="submit" class="btn btn-primary" id="submitBtn">Next: Step {{ step + 1 }} →</button>
          {% else %}
            <button type="submit" class="btn btn-success" id="submitBtn">Create Character ✓</button>
          {% endif %}
        </div>
      </form>
    </div>

    {# Character Preview Card (Optional) #}
    {% if character.name %}
      <div class="character-preview">
        <h4>{{ character.name }}</h4>
        {% if character.ancestry %}<p><strong>Ancestry:</strong> {{ character.ancestry }}</p>{% endif %}
        {% if character.heritage %}<p><strong>Heritage:</strong> {{ character.heritage }}</p>{% endif %}
        {% if character.background %}<p><strong>Background:</strong> {{ character.background }}</p>{% endif %}
        {% if character.class %}<p><strong>Class:</strong> {{ character.class }}</p>{% endif %}
      </div>
    {% endif %}

  </div>
</div>
