{#
 # Reusable management form page wrapper.
 #}
<div class="dc-character-sheet dc-management-page">
  {% if back_url %}
    <div class="dc-sheet__nav">
      <a href="{{ back_url }}" class="dc-btn dc-btn-secondary">← {{ back_label ?: 'Back' }}</a>
    </div>
  {% endif %}

  <section class="dc-sheet__section">
    {% if page_title %}
      <h1 class="dc-sheet__section-title">{{ page_title }}</h1>
    {% endif %}

    {% if page_description %}
      <p class="dc-management-page__description">{{ page_description }}</p>
    {% endif %}

    <div class="dc-management-page__form">
      {{ form }}
    </div>
  </section>
</div>
