{#
/**
 * @file
 * Template for the PF2E requirements implementation roadmap page.
 *
 * Available variables:
 * - books: Array of book data with chapters, sections, and requirements.
 * - totals: { pending, in_progress, implemented }
 * - total: Total requirement count.
 * - impl_pct: Percentage implemented (0–100).
 * - prog_pct: Percentage in progress (0–100).
 * - is_admin: Whether the current user can update statuses.
 * - backlog_groups: Grouped backlog features from HQ feature briefs.
 * - status_labels: Map of status => human label.
 */
#}
<div class="dc-roadmap">

  {# ── Page header ──────────────────────────────────────────────────────── #}
  <section class="dc-roadmap__header">
    <h1 class="dc-roadmap__title">PF2E Implementation Roadmap</h1>
    <p class="dc-roadmap__subtitle">
      Tracking {{ total }} requirements extracted from 9 Pathfinder 2E rulebooks.
    </p>
    <p class="dc-roadmap__subtitle">
      Requirements linked to a <code>feature_id</code> inherit status from the live pipeline automatically; unlinked requirements fall back to roadmap import status.
    </p>
    <p class="dc-roadmap__nav">
      <a href="https://forseti.life/roadmap">Forseti portfolio roadmap</a>
      &nbsp;|&nbsp;
      <a href="/architecture">System architecture</a>
    </p>

    <div class="dc-roadmap__stats-grid">
      <article class="dc-roadmap__stat-card">
        <span class="dc-roadmap__stat-label">Requirements tracked</span>
        <strong class="dc-roadmap__stat-value">{{ total }}</strong>
      </article>
      <article class="dc-roadmap__stat-card">
        <span class="dc-roadmap__stat-label">Implemented</span>
        <strong class="dc-roadmap__stat-value">{{ totals.implemented }}</strong>
      </article>
      <article class="dc-roadmap__stat-card">
        <span class="dc-roadmap__stat-label">In progress</span>
        <strong class="dc-roadmap__stat-value">{{ totals.in_progress }}</strong>
      </article>
      <article class="dc-roadmap__stat-card">
        <span class="dc-roadmap__stat-label">Not started</span>
        <strong class="dc-roadmap__stat-value">{{ totals.pending }}</strong>
      </article>
    </div>

    {# Overall progress bar #}
    <div class="dc-roadmap__progress-wrap">
      <div class="dc-roadmap__progress-bar" title="{{ impl_pct }}% implemented, {{ prog_pct }}% in progress">
        <div class="dc-roadmap__progress-fill dc-roadmap__progress-fill--implemented"
             style="width: {{ impl_pct }}%"></div>
        <div class="dc-roadmap__progress-fill dc-roadmap__progress-fill--in-progress"
             style="width: {{ prog_pct }}%; left: {{ impl_pct }}%"></div>
      </div>
      <div class="dc-roadmap__progress-legend">
        <span class="dc-status-badge dc-status-badge--implemented">✅ {{ totals.implemented }} Implemented ({{ impl_pct }}%)</span>
        <span class="dc-status-badge dc-status-badge--in_progress">🔄 {{ totals.in_progress }} In Progress ({{ prog_pct }}%)</span>
        <span class="dc-status-badge dc-status-badge--pending">❌ {{ totals.pending }} Not Started</span>
      </div>
    </div>
  </section>

  {% if backlog_groups %}
    <section class="dc-roadmap__backlog">
      <div class="dc-roadmap__backlog-header">
        <h2 class="dc-roadmap__backlog-title">Queued feature backlog</h2>
        <p class="dc-roadmap__backlog-copy">
          Groomed Dungeoncrawler feature briefs tracked in HQ but not yet mapped to individual PF2E requirement rows.
        </p>
      </div>

      <div class="dc-roadmap__backlog-groups">
        {% for group in backlog_groups %}
          <section class="dc-roadmap__backlog-group">
            <div class="dc-roadmap__backlog-group-header">
              <h3 class="dc-roadmap__backlog-group-title">{{ group.title }}</h3>
              <div class="dc-roadmap__backlog-group-stats">
                {% if group.counts.queued %}
                  <span class="dc-status-badge dc-status-badge--queued">{{ group.counts.queued }} Queued</span>
                {% endif %}
                {% if group.counts.in_progress %}
                  <span class="dc-status-badge dc-status-badge--in_progress">{{ group.counts.in_progress }} In Progress</span>
                {% endif %}
              </div>
            </div>

            <ul class="dc-roadmap__backlog-list">
              {% for feature in group.features %}
                <li class="dc-roadmap__backlog-item">
                  <div class="dc-roadmap__backlog-item-main">
                    <span class="dc-roadmap__backlog-item-title">{{ feature.title }}</span>
                    <code class="dc-roadmap__backlog-item-id">{{ feature.feature_id }}</code>
                  </div>
                  <div class="dc-roadmap__backlog-item-meta">
                    <span class="dc-status-badge dc-status-badge--{{ feature.display_status }}">{{ feature.status_label }}</span>
                    <span class="dc-roadmap__backlog-priority">{{ feature.priority }}</span>
                    {% if feature.release and feature.release != 'unscoped' and feature.release != '-' %}
                      <span class="dc-roadmap__backlog-release">{{ feature.release }}</span>
                    {% endif %}
                  </div>
                </li>
              {% endfor %}
            </ul>
          </section>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Per-book summary strip ────────────────────────────────────────────── #}
  <section class="dc-roadmap__summary-panel">
    <div class="dc-roadmap__panel-header">
      <h2 class="dc-roadmap__panel-title">Book completion</h2>
      <p class="dc-roadmap__panel-copy">Quick progress scan across the imported rulebook set.</p>
    </div>
    <div class="dc-roadmap__book-summary">
      {% for book in books %}
        {% set book_total = book.counts.pending + book.counts.in_progress + book.counts.implemented %}
        {% set book_pct = book_total > 0 ? ((book.counts.implemented / book_total) * 100)|round : 0 %}
        <div class="dc-roadmap__book-chip">
          <span class="dc-roadmap__book-chip-name">{{ book.title }}</span>
          <div class="dc-roadmap__book-chip-bar" title="{{ book_pct }}% implemented">
            <div class="dc-roadmap__book-chip-fill" style="width: {{ book_pct }}%"></div>
          </div>
          <span class="dc-roadmap__book-chip-pct">{{ book_pct }}%</span>
        </div>
      {% endfor %}
    </div>
  </section>

  {# ── Books ─────────────────────────────────────────────────────────────── #}
  <section class="dc-roadmap__books-panel">
    <div class="dc-roadmap__panel-header">
      <h2 class="dc-roadmap__panel-title">Requirement details</h2>
      <p class="dc-roadmap__panel-copy">Expand a rulebook, then drill into chapters and sections to inspect mapped implementation status.</p>
    </div>
    {% for book in books %}
      {% set book_total = book.counts.pending + book.counts.in_progress + book.counts.implemented %}
      {% set book_pct   = book_total > 0 ? ((book.counts.implemented / book_total) * 100)|round : 0 %}

      <details class="dc-roadmap__book" id="book-{{ book.id }}">
        <summary class="dc-roadmap__book-summary-row">
          <span class="dc-roadmap__book-name">{{ book.title }}</span>
          <span class="dc-roadmap__book-stats">
            <span class="dc-status-badge dc-status-badge--implemented">{{ book.counts.implemented }}</span>
            <span class="dc-status-badge dc-status-badge--in_progress">{{ book.counts.in_progress }}</span>
            <span class="dc-status-badge dc-status-badge--pending">{{ book.counts.pending }}</span>
            <span class="dc-roadmap__book-pct">{{ book_pct }}%</span>
          </span>
        </summary>

        {# ── Chapters ──────────────────────────────────────────────────────── #}
        {% for chapter in book.chapters %}
          {% set ch_total = chapter.counts.pending + chapter.counts.in_progress + chapter.counts.implemented %}
          {% set ch_pct   = ch_total > 0 ? ((chapter.counts.implemented / ch_total) * 100)|round : 0 %}

          <details class="dc-roadmap__chapter" id="chapter-{{ book.id }}-{{ chapter.key }}">
            <summary class="dc-roadmap__chapter-summary">
              <span class="dc-roadmap__chapter-title">{{ chapter.title }}</span>
              <span class="dc-roadmap__chapter-stats">
                <span class="dc-status-badge dc-status-badge--implemented">{{ chapter.counts.implemented }}</span>
                <span class="dc-status-badge dc-status-badge--in_progress">{{ chapter.counts.in_progress }}</span>
                <span class="dc-status-badge dc-status-badge--pending">{{ chapter.counts.pending }}</span>
                <span class="dc-roadmap__chapter-pct">{{ ch_pct }}%</span>
              </span>
            </summary>

            {# ── Sections ────────────────────────────────────────────────── #}
            {% for section_name, reqs in chapter.sections %}
              <div class="dc-roadmap__section">
                <h4 class="dc-roadmap__section-title">{{ section_name }}</h4>
                <ul class="dc-roadmap__req-list">
                  {% for req in reqs %}
                    <li class="dc-roadmap__req dc-roadmap__req--{{ req.display_status }}"
                        data-req-id="{{ req.id }}">
                      <span class="dc-roadmap__req-status">
                        <span class="dc-status-badge dc-status-badge--{{ req.display_status }}">
                          {{ req.status_label }}
                        </span>
                        {% if req.feature_id %}
                          <span class="dc-roadmap__feature-id" title="Release feature: {{ req.feature_id }}">{{ req.feature_id }}</span>
                        {% endif %}
                      </span>
                      <span class="dc-roadmap__req-text">
                        {% if req.paragraph_title %}
                          <em class="dc-roadmap__req-para">{{ req.paragraph_title }}:</em>
                        {% endif %}
                        {{ req.req_text }}
                      </span>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endfor %}

          </details>
        {% endfor %}

      </details>
    {% endfor %}
  </section>

  {% if total == 0 %}
    <div class="dc-roadmap__empty">
      <p>No requirements have been imported yet.</p>
      <p>Run <code>drush dungeoncrawler:import-requirements</code> to populate the roadmap.</p>
    </div>
  {% endif %}

</div>{# /.dc-roadmap #}
