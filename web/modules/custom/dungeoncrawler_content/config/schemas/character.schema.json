{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dungeoncrawler.life/schemas/character.schema.json",
  "title": "Pathfinder 2E Character Schema",
  "description": "Complete character data structure for a PF2e character stored in the dc_characters table character_data JSON column.",
  "type": "object",
  "required": ["schema_version", "step", "name", "level", "ancestry", "class", "abilities"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version for migration compatibility (semantic versioning: e.g., '1.0.0').",
      "default": "1.0.0"
    },
    "step": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "description": "Current step in character creation wizard (1-8). 8 = complete."
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Character's name."
    },
    "concept": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Character concept or hook - optional flavor text."
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 1,
      "description": "Character level."
    },
    "experience_points": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Current XP. 1000 XP per level. This field is mirrored in the dc_campaign_characters.experience_points hot column for high-frequency gameplay reads/writes."
    },
    "ancestry": {
      "type": "string",
      "enum": [
        "Human", "Elf", "Dwarf", "Gnome", "Goblin", "Halfling",
        "Half-Elf", "Half-Orc", "Leshy", "Orc", "Catfolk", "Kobold",
        "Ratfolk", "Tengu"
      ],
      "description": "PF2e ancestry choice."
    },
    "heritage": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Heritage specific to chosen ancestry (e.g., 'Ancient-Blooded Dwarf', 'Woodland Elf', 'Gutsy Halfling')."
    },
    "background": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Background ID (e.g., 'acolyte', 'criminal', 'noble')."
    },
    "background_boosts": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["str", "dex", "con", "int", "wis", "cha"],
        "description": "Ability score to boost (str/dex/con/int/wis/cha)."
      },
      "minItems": 2,
      "maxItems": 2,
      "description": "Two ability boosts chosen from background. Player's choice."
    },
    "class": {
      "type": "string",
      "enum": [
        "Alchemist", "Barbarian", "Bard", "Champion", "Cleric", "Druid",
        "Fighter", "Monk", "Ranger", "Rogue", "Sorcerer", "Wizard"
      ],
      "description": "PF2e class choice."
    },
    "subclass": {
      "type": "string",
      "maxLength": 100,
      "description": "Class-specific subclass (e.g., Fighter weapon group, Wizard school, Sorcerer bloodline)."
    },
    "free_boosts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/ability_boost"
      },
      "description": "Tracking of all ability boosts applied to character.",
      "examples": [
        [
          {
            "source": "ancestry",
            "ability": "str",
            "value": 2
          },
          {
            "source": "background",
            "ability": "dex",
            "value": 2
          },
          {
            "source": "class",
            "ability": "str",
            "value": 2
          },
          {
            "source": "level_1",
            "ability": "int",
            "value": 2
          }
        ]
      ]
    },
    "abilities": {
      "type": "object",
      "required": ["str", "dex", "con", "int", "wis", "cha"],
      "properties": {
        "str": {
          "$ref": "#/definitions/ability_score",
          "description": "Strength score."
        },
        "dex": {
          "$ref": "#/definitions/ability_score",
          "description": "Dexterity score."
        },
        "con": {
          "$ref": "#/definitions/ability_score",
          "description": "Constitution score."
        },
        "int": {
          "$ref": "#/definitions/ability_score",
          "description": "Intelligence score."
        },
        "wis": {
          "$ref": "#/definitions/ability_score",
          "description": "Wisdom score."
        },
        "cha": {
          "$ref": "#/definitions/ability_score",
          "description": "Charisma score."
        }
      },
      "additionalProperties": false,
      "description": "Current ability scores after all boosts and flaws."
    },
    "hit_points": {
      "type": "object",
      "required": ["max", "current"],
      "properties": {
        "max": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum HP (ancestry + class + Con modifier per level). This field is mirrored in the dc_campaign_characters.hp_max hot column."
        },
        "current": {
          "type": "integer",
          "minimum": 0,
          "description": "Current HP. Must not exceed max. This field is mirrored in the dc_campaign_characters.hp_current hot column for high-frequency gameplay reads/writes."
        },
        "temp": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000,
          "default": 0,
          "description": "Temporary HP."
        }
      },
      "additionalProperties": false,
      "description": "Character hit points. Note: Schema validation cannot enforce that current HP <= max HP; this must be validated at the application level. The max and current values are stored in both this JSON structure and as dedicated hot columns (hp_max, hp_current) in dc_campaign_characters for performance."
    },
    "armor_class": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 10,
      "description": "Character's Armor Class (AC). Calculated as 10 + DEX modifier + armor bonus + shield bonus + other bonuses. This field is mirrored in the dc_campaign_characters.armor_class hot column for high-frequency gameplay reads/writes."
    },
    "alignment": {
      "type": "string",
      "enum": ["LG", "NG", "CG", "LN", "N", "CN", "LE", "NE", "CE"],
      "description": "Character alignment (pre-Remaster legacy support)."
    },
    "deity": {
      "type": "string",
      "maxLength": 100,
      "description": "Deity worshipped (if any). Required for clerics and champions."
    },
    "age": {
      "type": "string",
      "maxLength": 50,
      "pattern": "^[0-9a-zA-Z\\s,\\-]+$",
      "description": "Character's age. Can be numeric (e.g., '25') or descriptive (e.g., 'young adult', 'ancient'). Different ancestries age at different rates."
    },
    "gender": {
      "type": "string",
      "maxLength": 100,
      "description": "Character's gender identity."
    },
    "size": {
      "type": "string",
      "enum": ["Tiny", "Small", "Medium", "Large"],
      "default": "Medium",
      "description": "Character size (from ancestry)."
    },
    "speed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120,
      "default": 25,
      "description": "Base movement speed in feet."
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50,
        "description": "Language name (e.g., 'Common', 'Elvish', 'Draconic')."
      },
      "uniqueItems": true,
      "description": "Languages known."
    },
    "skills": {
      "type": "object",
      "description": "Skill proficiencies: untrained, trained, expert, master, legendary.",
      "patternProperties": {
        "^[a-z]+(_[a-z]+)*$": {
          "type": "string",
          "enum": ["untrained", "trained", "expert", "master", "legendary"],
          "description": "Proficiency rank for this skill."
        }
      },
      "examples": [
        {
          "acrobatics": "trained",
          "athletics": "expert",
          "stealth": "trained",
          "perception": "expert"
        }
      ]
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Single equipment item with quantity and equipped status. Note: Future versions may include bulk, price, and rarity properties.",
        "required": ["item_id", "name", "quantity"],
        "properties": {
          "item_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Item identifier."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Item name."
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "default": 1,
            "description": "Number of items."
          },
          "equipped": {
            "type": "boolean",
            "default": false,
            "description": "Whether item is currently equipped."
          },
          "worn": {
            "type": "boolean",
            "default": false,
            "description": "Whether item is worn (armor, clothing)."
          }
        },
        "additionalProperties": false
      },
      "description": "Character's equipment and inventory.",
      "examples": [
        [
          {
            "item_id": "longsword-001",
            "name": "Longsword",
            "quantity": 1,
            "equipped": true,
            "worn": false
          },
          {
            "item_id": "leather-armor-001",
            "name": "Leather Armor",
            "quantity": 1,
            "equipped": false,
            "worn": true
          }
        ]
      ]
    },
    "gold": {
      "type": "integer",
      "minimum": 0,
      "maximum": 999999999,
      "default": 15,
      "description": "Gold pieces. Characters start with 15 gp."
    },
    "appearance": {
      "type": "string",
      "maxLength": 1000,
      "description": "Physical description. Optional flavor text for roleplaying."
    },
    "personality": {
      "type": "string",
      "maxLength": 1000,
      "description": "Personality traits. Optional flavor text for roleplaying."
    },
    "backstory": {
      "type": "string",
      "maxLength": 5000,
      "description": "Character backstory. Optional flavor text for roleplaying."
    },
    "portrait_generate": {
      "type": "boolean",
      "default": true,
      "description": "Whether to generate a portrait when character creation completes."
    },
    "portrait_prompt": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional user prompt to guide portrait generation."
    },
    "feats": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "description": "Individual feat with acquisition details.",
        "required": ["feat_id", "name", "level_gained", "feat_type"],
        "properties": {
          "feat_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Unique feat identifier."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Feat name."
          },
          "level_gained": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "Character level when feat was gained."
          },
          "feat_type": {
            "type": "string",
            "enum": ["ancestry", "class", "skill", "general"],
            "description": "Category of feat."
          }
        },
        "additionalProperties": false
      },
      "description": "Feats acquired through leveling.",
      "examples": [
        [
          {
            "feat_id": "toughness",
            "name": "Toughness",
            "level_gained": 1,
            "feat_type": "general"
          },
          {
            "feat_id": "power-attack",
            "name": "Power Attack",
            "level_gained": 1,
            "feat_type": "class"
          }
        ]
      ]
    },
    "spells": {
      "type": "object",
      "properties": {
        "tradition": {
          "type": "string",
          "enum": ["arcane", "divine", "occult", "primal"],
          "description": "Spellcasting tradition (if any)."
        },
        "spell_attack": {
          "type": "integer",
          "minimum": -10,
          "maximum": 50,
          "description": "Spell attack modifier."
        },
        "spell_dc": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60,
          "description": "Spell DC."
        },
        "spells_known": {
          "type": "array",
          "items": {
            "type": "object",
            "description": "Individual spell with rank information.",
            "required": ["spell_id", "name", "rank"],
            "properties": {
              "spell_id": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "description": "Unique spell identifier."
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200,
                "description": "Spell name."
              },
              "rank": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10,
                "description": "Spell rank. 0 = cantrip, 1-10 = spell level (PF2e supports up to rank 10 spells at level 20)."
              }
            },
            "additionalProperties": false
          },
          "description": "List of spells the character knows.",
          "examples": [
            [
              {
                "spell_id": "detect-magic",
                "name": "Detect Magic",
                "rank": 0
              },
              {
                "spell_id": "magic-missile",
                "name": "Magic Missile",
                "rank": 1
              }
            ]
          ]
        },
        "spell_slots": {
          "type": "object",
          "description": "Spell slots per rank. Keys must be 'rank_0' through 'rank_10' for cantrips through 10th-level spells.",
          "patternProperties": {
            "^rank_(10|[0-9])$": {
              "$ref": "#/definitions/spell_slot"
            }
          },
          "additionalProperties": false
        },
        "focus_points": {
          "type": "object",
          "required": ["max", "remaining"],
          "properties": {
            "max": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3,
              "default": 0,
              "description": "Maximum focus points."
            },
            "remaining": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3,
              "description": "Current focus points remaining."
            }
          },
          "description": "Focus points for focus spells and class abilities."
        }
      },
      "additionalProperties": false,
      "description": "Spellcasting data (null if not a spellcaster)."
    },
    "conditions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "description": "Active condition with optional value and duration.",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Condition name (e.g., 'Blinded', 'Fatigued', 'Wounded 1')."
          },
          "value": {
            "type": ["integer", "null"],
            "description": "Numeric value for conditions with levels (e.g., Wounded 2)."
          },
          "duration": {
            "type": ["string", "null"],
            "description": "Duration of condition (e.g., '1 round', 'until healed')."
          }
        },
        "additionalProperties": false
      },
      "description": "Active PF2e conditions.",
      "examples": [
        [
          {
            "name": "Wounded",
            "value": 1,
            "duration": "until healed"
          },
          {
            "name": "Fatigued",
            "value": null,
            "duration": "until rest"
          }
        ]
      ]
    },
    "hero_points": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "default": 1,
      "description": "Hero points (refresh at session start)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Character creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last modification timestamp."
    }
  },
  "definitions": {
    "ability_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30,
      "default": 10,
      "description": "Character ability score."
    },
    "ability_boost": {
      "type": "object",
      "description": "Records a single ability boost with its source and amount.",
      "required": ["source", "ability"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["ancestry", "background", "class", "level_1", "level_5", "level_10", "level_15", "level_20"],
          "description": "Where this boost came from."
        },
        "ability": {
          "type": "string",
          "enum": ["str", "dex", "con", "int", "wis", "cha"],
          "description": "Which ability was boosted."
        },
        "value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2,
          "default": 2,
          "description": "Boost amount (+2 typical, +1 if already 18+)."
        }
      },
      "additionalProperties": false
    },
    "spell_slot": {
      "type": "object",
      "required": ["max", "remaining"],
      "properties": {
        "max": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum spell slots for this rank."
        },
        "remaining": {
          "type": "integer",
          "minimum": 0,
          "description": "Remaining spell slots for this rank."
        }
      },
      "additionalProperties": false
    }
  }
}
