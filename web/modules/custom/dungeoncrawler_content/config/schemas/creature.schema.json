{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dungeoncrawler.life/schemas/creature.schema.json",
  "title": "Creature Schema",
  "description": "A creature living in the dungeon \u2014 monster, NPC, or beast. Has AI-driven personality, goals, and PF2e-compatible combat statistics. Permanent creatures die forever; respawning creatures return after a cooldown.",
  "type": "object",
  "required": [
    "creature_id",
    "name",
    "level",
    "creature_type",
    "pf2e_stats",
    "ai_personality",
    "lifecycle"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version for migration compatibility (semantic versioning: e.g., '1.0.0').",
      "default": "1.0.0"
    },
    "creature_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this creature."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Display name. AI-generated creatures get unique names.",
      "examples": [
        "Gribbles Rindsworth the Magnificent",
        "Skullgnaw the Hungering"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional title/epithet.",
      "examples": [
        "the Magnificent",
        "Guardian of the Fungal Pantry"
      ]
    },
    "level": {
      "type": "integer",
      "minimum": -1,
      "maximum": 25,
      "description": "PF2e creature level. Determines stats, DCs, and XP reward. Level -1 represents creatures weaker than level 0 (e.g., vermin)."
    },
    "creature_type": {
      "type": "string",
      "enum": [
        "aberration",
        "animal",
        "astral",
        "beast",
        "celestial",
        "construct",
        "dragon",
        "dream",
        "elemental",
        "ethereal",
        "fey",
        "fiend",
        "fungus",
        "giant",
        "humanoid",
        "monitor",
        "ooze",
        "plant",
        "spirit",
        "undead"
      ],
      "description": "PF2e creature type (trait)."
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "uniqueItems": true,
      "description": "PF2e traits (e.g., ['Goblin', 'Humanoid', 'Small'])."
    },
    "alignment": {
      "type": "string",
      "enum": [
        "LG",
        "NG",
        "CG",
        "LN",
        "N",
        "CN",
        "LE",
        "NE",
        "CE"
      ],
      "description": "Alignment (pre-Remaster legacy support)."
    },
    "rarity": {
      "type": "string",
      "enum": [
        "common",
        "uncommon",
        "rare",
        "unique"
      ],
      "default": "common",
      "description": "Rarity of the creature: common (standard encounters), uncommon (special encounters), rare (boss-level), unique (one-of-a-kind NPCs)."
    },
    "size": {
      "type": "string",
      "enum": [
        "tiny",
        "small",
        "medium",
        "large",
        "huge",
        "gargantuan"
      ],
      "description": "PF2e size category. Determines hex occupation: tiny/small/medium=1, large=3-4, huge=7, gargantuan=12+."
    },
    "hex_footprint": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of hexes this creature occupies.",
      "maximum": 30
    },
    "pf2e_stats": {
      "type": "object",
      "description": "Full PF2e-compatible stat block.",
      "required": [
        "ability_scores",
        "hp",
        "ac",
        "saves",
        "perception",
        "speed"
      ],
      "additionalProperties": false,
      "properties": {
        "ability_scores": {
          "type": "object",
          "properties": {
            "strength": {
              "$ref": "#/definitions/ability_score"
            },
            "dexterity": {
              "$ref": "#/definitions/ability_score"
            },
            "constitution": {
              "$ref": "#/definitions/ability_score"
            },
            "intelligence": {
              "$ref": "#/definitions/ability_score"
            },
            "wisdom": {
              "$ref": "#/definitions/ability_score"
            },
            "charisma": {
              "$ref": "#/definitions/ability_score"
            }
          },
          "required": [
            "strength",
            "dexterity",
            "constitution",
            "intelligence",
            "wisdom",
            "charisma"
          ],
          "additionalProperties": false
        },
        "hp": {
          "type": "object",
          "properties": {
            "max": {
              "type": "integer",
              "minimum": 1,
              "maximum": 9999,
              "description": "Maximum hit points. Typical range: 1-500 for most creatures, up to 9999 for mythic bosses."
            },
            "current": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9999,
              "description": "Current hit points. Can exceed max when temporary HP is applied."
            },
            "temporary": {
              "type": "integer",
              "default": 0,
              "minimum": 0,
              "maximum": 500,
              "description": "Temporary hit points. Typical range: 0-100."
            },
            "hardness": {
              "type": "integer",
              "default": 0,
              "minimum": 0,
              "maximum": 50,
              "description": "Physical hardness (for constructs/objects). Typical range: 0-30."
            },
            "immunities": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "uniqueItems": true,
              "description": "Damage types or conditions the creature is immune to (e.g., 'fire', 'poison', 'paralyzed')."
            },
            "resistances": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "value": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 30
                  }
                },
                "required": [
                  "type",
                  "value"
                ],
                "additionalProperties": false
              }
            },
            "weaknesses": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                  },
                  "value": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 30
                  }
                },
                "required": [
                  "type",
                  "value"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "max",
            "current"
          ],
          "additionalProperties": false
        },
        "ac": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Armor Class. The DC to hit this creature with attacks. Typical range: 10-40."
        },
        "saves": {
          "type": "object",
          "properties": {
            "fortitude": {
              "$ref": "#/definitions/save"
            },
            "reflex": {
              "$ref": "#/definitions/save"
            },
            "will": {
              "$ref": "#/definitions/save"
            }
          },
          "required": [
            "fortitude",
            "reflex",
            "will"
          ],
          "additionalProperties": false
        },
        "perception": {
          "type": "object",
          "required": [
            "modifier"
          ],
          "additionalProperties": false,
          "properties": {
            "modifier": {
              "type": "integer",
              "minimum": -10,
              "maximum": 40
            },
            "senses": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "examples": [
                "darkvision",
                "scent (imprecise) 30 feet",
                "tremorsense 60 feet"
              ]
            }
          }
        },
        "speed": {
          "type": "object",
          "description": "Movement speeds in feet.",
          "required": [
            "land"
          ],
          "additionalProperties": false,
          "properties": {
            "land": {
              "type": "integer",
              "minimum": 0,
              "maximum": 120,
              "default": 25,
              "description": "Base land speed in feet. Typical range 5-60 for most creatures."
            },
            "fly": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0,
              "maximum": 200,
              "description": "Fly speed in feet, or null if creature cannot fly."
            },
            "swim": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0,
              "maximum": 100,
              "description": "Swim speed in feet, or null if creature has no swim speed."
            },
            "climb": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0,
              "maximum": 100,
              "description": "Climb speed in feet, or null if creature has no climb speed."
            },
            "burrow": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0,
              "maximum": 60,
              "description": "Burrow speed in feet, or null if creature cannot burrow."
            }
          }
        },
        "skills": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "modifier"
            ],
            "additionalProperties": false,
            "properties": {
              "modifier": {
                "type": "integer",
                "minimum": -10,
                "maximum": 50,
                "description": "Skill modifier including ability modifier, proficiency bonus, and any item/circumstance bonuses."
              },
              "proficiency": {
                "type": "string",
                "enum": [
                  "untrained",
                  "trained",
                  "expert",
                  "master",
                  "legendary"
                ],
                "description": "Proficiency rank in this skill."
              }
            }
          }
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Languages the creature can speak, understand, or read.",
          "examples": [
            ["Common", "Goblin"],
            ["Draconic", "Common"],
            []
          ]
        },
        "attacks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/attack"
          }
        },
        "special_abilities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ability"
          }
        },
        "spells": {
          "type": [
            "object",
            "null"
          ],
          "description": "Innate or prepared spells.",
          "properties": {
            "tradition": {
              "type": "string",
              "enum": [
                "arcane",
                "divine",
                "occult",
                "primal"
              ],
              "description": "Magical tradition: arcane (wizards/scholars), divine (gods/faith), occult (psychic/esoteric), primal (nature/instinct)."
            },
            "type": {
              "type": "string",
              "enum": [
                "innate",
                "prepared",
                "spontaneous",
                "focus"
              ],
              "description": "Spellcasting type: innate (racial/natural), prepared (daily selection), spontaneous (known spells), focus (limited pool)."
            },
            "dc": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "description": "Spell DC for saving throws."
            },
            "attack_modifier": {
              "type": "integer",
              "minimum": -5,
              "maximum": 40,
              "description": "Spell attack modifier."
            },
            "spell_slots": {
              "type": "object",
              "description": "Spell slots by level (keys are spell levels '0' through '10').",
              "additionalProperties": {
                "type": "object",
                "required": [
                  "slots",
                  "spells"
                ],
                "additionalProperties": false,
                "properties": {
                  "slots": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 10,
                    "description": "Number of spell slots at this level."
                  },
                  "spells": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "uniqueItems": true,
                    "description": "List of spell names available at this level."
                  }
                }
              }
            }
          }
        }
      }
    },
    "ai_personality": {
      "type": "object",
      "description": "AI-driven personality system. Powers NPC dialogue, combat decisions, and inter-creature relationships.",
      "required": [
        "disposition",
        "personality_traits",
        "goals"
      ],
      "additionalProperties": false,
      "properties": {
        "disposition": {
          "type": "string",
          "enum": [
            "hostile",
            "unfriendly",
            "indifferent",
            "friendly",
            "helpful"
          ],
          "description": "Default disposition toward unknown adventurers."
        },
        "personality_traits": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Core personality descriptors for AI dialogue generation.",
          "examples": [
            [
              "Cowardly but cunning",
              "Obsessed with cheese",
              "Loyal once bribed"
            ]
          ]
        },
        "goals": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "string",
              "minLength": 1
            },
            "secondary": {
              "type": "string",
              "minLength": 1
            },
            "tertiary": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "primary"
          ],
          "additionalProperties": false
        },
        "fears": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Things this creature fears or avoids."
        },
        "desires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Things this creature wants or seeks."
        },
        "speech_patterns": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dialect": {
              "type": "string",
              "minLength": 1,
              "description": "Regional or cultural dialect (e.g., 'Broken Common', 'Courtly Elvish')."
            },
            "catchphrases": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "description": "Phrases this creature commonly uses."
            },
            "verbal_tics": {
              "type": "string",
              "minLength": 1,
              "description": "Speech quirks or mannerisms (e.g., 'hisses s-sounds', 'ends sentences with \"yes?\"')."
            },
            "formality": {
              "type": "string",
              "enum": [
                "crude",
                "casual",
                "formal",
                "archaic",
                "alien"
              ],
              "description": "Overall tone and formality level of speech."
            }
          }
        },
        "combat_personality": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "aggression": {
              "type": "string",
              "enum": [
                "pacifist",
                "defensive",
                "cautious",
                "aggressive",
                "berserk"
              ],
              "description": "How willing the creature is to initiate or escalate combat."
            },
            "tactics": {
              "type": "string",
              "enum": [
                "mindless",
                "instinctive",
                "basic",
                "tactical",
                "strategic",
                "genius"
              ],
              "description": "Level of strategic thinking in combat."
            },
            "morale": {
              "type": "string",
              "enum": [
                "cowardly",
                "cautious",
                "steady",
                "brave",
                "fanatical"
              ],
              "description": "Willingness to continue fighting when things go badly."
            },
            "flee_threshold_hp_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "HP percentage below which creature attempts to flee (0-100)."
            },
            "preferred_targets": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true,
              "description": "Types of enemies this creature prefers to attack (e.g., 'spellcaster', 'weakest', 'leader')."
            },
            "preferred_range": {
              "type": "string",
              "enum": [
                "melee",
                "ranged",
                "mixed",
                "flee"
              ],
              "description": "Combat range preference."
            }
          }
        },
        "memory": {
          "type": "array",
          "description": "AI memory of past interactions with players. Grows over time.",
          "items": {
            "type": "object",
            "properties": {
              "event": {
                "type": "string",
                "minLength": 1
              },
              "party_id": {
                "type": "string",
                "format": "uuid"
              },
              "sentiment": {
                "type": "string",
                "enum": [
                  "very_negative",
                  "negative",
                  "neutral",
                  "positive",
                  "very_positive"
                ],
                "description": "Emotional sentiment of the memory: very_negative (traumatic), negative (unpleasant), neutral, positive (pleasant), very_positive (cherished)."
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": [
              "event",
              "party_id",
              "timestamp"
            ],
            "additionalProperties": false
          }
        },
        "relationships": {
          "type": "object",
          "description": "Relationships with other creatures in the dungeon. Keys are creature IDs.",
          "additionalProperties": {
            "type": "object",
            "required": [
              "creature_id",
              "sentiment"
            ],
            "additionalProperties": false,
            "properties": {
              "creature_id": {
                "type": "string",
                "format": "uuid",
                "description": "UUID of the related creature."
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Name of the related creature (for convenience)."
              },
              "relationship": {
                "type": "string",
                "minLength": 1,
                "description": "Description of the relationship (e.g., 'brother', 'sworn enemy', 'former master')."
              },
              "sentiment": {
                "type": "string",
                "enum": [
                  "enemy",
                  "rival",
                  "neutral",
                  "ally",
                  "devoted"
                ],
                "description": "Overall sentiment toward this creature."
              }
            }
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "description": "Creature lifecycle management \u2014 permadeath, respawning, wandering.",
      "required": [
        "spawn_type",
        "is_alive"
      ],
      "additionalProperties": false,
      "properties": {
        "spawn_type": {
          "type": "string",
          "enum": [
            "permanent",
            "respawning",
            "wandering",
            "boss",
            "quest",
            "summoned"
          ],
          "description": "permanent=dies forever, respawning=returns, wandering=roams between rooms, boss=unique encounter."
        },
        "is_alive": {
          "type": "boolean",
          "default": true
        },
        "death_timestamp": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "killed_by_party": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid",
          "description": "UUID of the party that killed this creature, or null if not killed or killed by environment."
        },
        "respawn_cooldown_hours": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "description": "Hours before creature respawns (for respawning spawn_type), or null if not applicable."
        },
        "next_respawn_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "home_room_id": {
          "type": "string",
          "description": "Room this creature considers home. May be empty if not yet assigned."
        },
        "current_room_id": {
          "type": "string",
          "description": "Room the creature is currently in. May be empty if not yet placed."
        },
        "patrol_route": {
          "type": "array",
          "description": "For wandering creatures: ordered list of room IDs they visit.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "wander_radius_rooms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 50,
          "description": "Maximum rooms from home this creature will wander (0 = stays in home room)."
        }
      }
    },
    "loot_table": {
      "type": "object",
      "description": "What this creature drops on death.",
      "additionalProperties": false,
      "properties": {
        "guaranteed": {
          "type": "array",
          "description": "Items that always drop when creature is defeated.",
          "items": {
            "$ref": "#/definitions/loot_entry"
          }
        },
        "random": {
          "type": "array",
          "description": "Items that may drop based on drop_chance.",
          "items": {
            "type": "object",
            "required": [
              "item",
              "drop_chance"
            ],
            "additionalProperties": false,
            "properties": {
              "item": {
                "$ref": "#/definitions/loot_entry"
              },
              "drop_chance": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Probability of this item dropping (0.0 to 1.0)."
              }
            }
          }
        },
        "currency": {
          "type": "object",
          "properties": {
            "cp_range": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1000
              },
              "minItems": 2,
              "maxItems": 2,
              "description": "Copper pieces drop range [min, max]. Typical: [0, 50] for low-level creatures."
            },
            "sp_range": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 500
              },
              "minItems": 2,
              "maxItems": 2,
              "description": "Silver pieces drop range [min, max]. Typical: [0, 20] for mid-level creatures."
            },
            "gp_range": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1000
              },
              "minItems": 2,
              "maxItems": 2,
              "description": "Gold pieces drop range [min, max]. Typical: [0, 100] for high-level creatures."
            }
          },
          "additionalProperties": false
        }
      }
    },
    "xp_reward": {
      "type": "integer",
      "description": "XP awarded for defeating this creature. Auto-calculated from PF2e level if omitted.",
      "minimum": 0,
      "maximum": 50000
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creature creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last modification timestamp."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Optional flavor text describing the creature."
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "description": "Source book or origin (e.g., 'Pathfinder Bestiary 1', 'AI-generated')."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "ability_score": {
      "type": "object",
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "modifier": {
          "type": "integer",
          "minimum": -5,
          "maximum": 10
        }
      },
      "required": [
        "score",
        "modifier"
      ],
      "additionalProperties": false
    },
    "hex_coordinate": {
      "type": "object",
      "description": "Axial coordinate for hex-based positioning.",
      "required": [
        "q",
        "r"
      ],
      "additionalProperties": false,
      "properties": {
        "q": {
          "type": "integer",
