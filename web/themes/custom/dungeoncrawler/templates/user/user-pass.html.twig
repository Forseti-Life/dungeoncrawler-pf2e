{#
/**
 * @file
 * Theme override for the user password reset form - Dungeon Crawler RPG.
 */
#}

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="text-center mb-5">
        <i class="fas fa-key fa-4x mb-4 dc-auth-icon"></i>
        <h1 class="mb-3 dc-heading-accent">Recover Your Credentials</h1>
        <p class="lead dc-auth-subtitle">The Guild Scribe will send a magical rune to your message crystal to restore your access.</p>
      </div>

      <div class="card-dungeoncrawler p-4">
        {{ form }}
      </div>

      <div class="text-center mt-4">
        <p class="text-muted">
          Remembered your credentials? <a href="/user/login" class="link-cyan">Return to the gates</a>
        </p>
      </div>
    </div>
  </div>
</div>
