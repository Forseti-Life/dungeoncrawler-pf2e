{#
/**
 * @file
 * Theme override for the user registration form - Dungeon Crawler RPG.
 */
#}

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="text-center mb-5">
        <i class="fas fa-scroll fa-4x mb-4 dc-auth-icon"></i>
        <h1 class="mb-3 dc-heading-accent">Join the Adventurers' Guild</h1>
        <p class="lead dc-auth-subtitle">Sign the Guild ledger to create your adventurer and descend into the AI-generated dungeon.</p>
      </div>

      <div class="card-dungeoncrawler p-4">
        {{ form }}

        <div class="text-center mt-4 pt-4 dc-auth-divider">
          <p class="text-muted mb-3">Or register with:</p>
          <div class="social-auth-container">
            <a class="social-auth auth-link btn btn-light" href="/user/login/google">
              <img class="social-auth auth-icon me-2 dc-auth-google-icon" src="/modules/contrib/social_auth_google/img/google_logo.svg" alt="Google logo">
              Sign up with Google
            </a>
          </div>
        </div>
      </div>

      <div class="text-center mt-4">
        <p class="text-muted">
          Already a Guild member? <a href="/user/login" class="link-cyan">Return to the depths</a>
        </p>
      </div>
    </div>
  </div>
</div>
