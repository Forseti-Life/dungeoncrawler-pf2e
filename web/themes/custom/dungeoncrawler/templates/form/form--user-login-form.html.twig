{#
/**
 * @file
 * Theme override for the user login form - Dungeon Crawler RPG.
 */
#}
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="text-center mb-5">
        <i class="fas fa-dungeon fa-4x mb-4 dc-auth-icon"></i>
        <h1 class="mb-3 dc-heading-accent">Return to the Depths</h1>
        <p class="lead dc-auth-subtitle">Present your credentials to the Guild Master and rejoin your adventuring party.</p>
      </div>

      <div class="card-dungeoncrawler p-4">
        <form{{ attributes }}>
          {{ children }}
        </form>
      </div>

      <div class="text-center mt-4">
        <p class="text-muted">
          New adventurer? <a href="/user/register" class="link-cyan">Join the Guild</a>
        </p>
        <p class="text-muted">
          <a href="/user/password" class="link-cyan">Lost your credentials?</a>
        </p>
      </div>
    </div>
  </div>
</div>